---
// src/components/Especialidades.astro
---

<section class="relative bg-slate-50 py-24 overflow-hidden" id="especialidades-section">
  <!-- Glowing background orbs -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#00a3e0]/10 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-[#004b87]/5 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-16 espp-header">
      <h2 class="text-3xl md:text-5xl font-black text-[#004b87] tracking-tight mb-4">Nuestras Especialidades Médicas</h2>
      <p class="text-slate-600 text-lg md:text-xl font-medium">Médicos avalados y tecnología de punta para un diagnóstico y tratamiento eficaz.</p>
    </div>

    <!-- Bento Grid - 4 Especialidades Principales -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 relative">
      
      <!-- Cardiología -->
      <a href="/directorio?especialidad=cardiologia" class="glass-card p-8 group hover:-translate-y-2 hover:shadow-[0_0_25px_#00a3e0] transition-all duration-300 flex flex-col items-center text-center bento-espp">
        <div class="w-16 h-16 bg-blue-50 text-[#00a3e0] rounded-2xl flex items-center justify-center mb-6 border border-blue-100 group-hover:bg-[#00a3e0] group-hover:text-white transition-colors duration-300">
          <i class="ph ph-heartbeat text-3xl"></i>
        </div>
        <h3 class="text-xl font-bold text-[#004b87] mb-3">Cardiología</h3>
        <p class="text-slate-600 text-sm flex-grow">Diagnóstico oportuno de enfermedades cardiovasculares con estudios no invasivos.</p>
      </a>

      <!-- Gastroenterología -->
      <a href="/directorio?especialidad=gastroenterologia" class="glass-card p-8 group hover:-translate-y-2 hover:shadow-[0_0_25px_#00a3e0] transition-all duration-300 flex flex-col items-center text-center bento-espp">
        <div class="w-16 h-16 bg-blue-50 text-[#00a3e0] rounded-2xl flex items-center justify-center mb-6 border border-blue-100 group-hover:bg-[#00a3e0] group-hover:text-white transition-colors duration-300">
          <i class="ph ph-stethoscope text-3xl"></i>
        </div>
        <h3 class="text-xl font-bold text-[#004b87] mb-3">Gastroenterología</h3>
        <p class="text-slate-600 text-sm flex-grow">Endoscopía de vanguardia y tratamientos integrales del sistema digestivo.</p>
      </a>

      <!-- Ginecología -->
      <a href="/directorio?especialidad=ginecologia" class="glass-card p-8 group hover:-translate-y-2 hover:shadow-[0_0_25px_#00a3e0] transition-all duration-300 flex flex-col items-center text-center bento-espp">
        <div class="w-16 h-16 bg-pink-50 text-pink-500 rounded-2xl flex items-center justify-center mb-6 border border-pink-100 group-hover:bg-pink-500 group-hover:text-white transition-colors duration-300">
           <i class="ph ph-gender-female text-3xl"></i>
        </div>
        <h3 class="text-xl font-bold text-[#004b87] mb-3">Ginecología</h3>
        <p class="text-slate-600 text-sm flex-grow">Acompañamiento especializado en todas las etapas de la mujer y embarazo.</p>
      </a>

      <!-- Traumatología -->
      <a href="/directorio?especialidad=traumatologia" class="glass-card p-8 group hover:-translate-y-2 hover:shadow-[0_0_25px_#00a3e0] transition-all duration-300 flex flex-col items-center text-center bento-espp">
        <div class="w-16 h-16 bg-blue-50 text-[#00a3e0] rounded-2xl flex items-center justify-center mb-6 border border-blue-100 group-hover:bg-[#00a3e0] group-hover:text-white transition-colors duration-300">
          <i class="ph ph-bone text-3xl"></i>
        </div>
        <h3 class="text-xl font-bold text-[#004b87] mb-3">Traumatología</h3>
        <p class="text-slate-600 text-sm flex-grow">Cirugías articulares y recuperación de lesiones musculoesqueléticas deportivas.</p>
      </a>

    </div>

    <!-- SEO AEO List (Visualmente disimulado pero accesible al DOM para bots) -->
    <div class="mt-8 text-center" aria-label="Especialidades adicionales">
      <p class="sr-only">
        También contamos con más de 40 especialidades médicas adicionales, como: Pediatría, Neurología, Urología, Oftalmología, Dermatología, Otorrinolaringología, Oncología, Cirugía General, Medicina Interna, Endocrinología, Neumología, Reumatología, Hematología, Nefrología, Psiquiatría y Nutrición, entre otras.
      </p>
      <!-- Botón visible para descubrir el resto -->
      <a href="/especialidades" class="inline-block mt-4 text-[#00a3e0] font-bold hover:text-[#004b87] transition-colors border-b-2 border-transparent hover:border-[#004b87] pb-1">
        Explorar más de 40 especialidades médicas &rarr;
      </a>
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      
      // Animación de Header de Especialidades
      gsap.fromTo(".espp-header", 
        { y: 30, opacity: 0 },
        { 
          y: 0, opacity: 1, duration: 1, ease: "power3.out",
          scrollTrigger: {
            trigger: "#especialidades-section",
            start: "top 80%",
          }
        }
      );

      // Stagger de las Cards
      gsap.fromTo(".bento-espp", 
        { y: 50, opacity: 0 },
        { 
          y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: "power3.out",
          scrollTrigger: {
            trigger: ".espp-header",
            start: "top 75%",
          }
        }
      );
    }
  });
</script>
