---

---

<footer class="bg-brand-blue text-white pt-16 pb-8 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Top Section: Identity & Links -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-12">
      <!-- Identity (5 cols) -->
      <div class="md:col-span-5">
        <a href="/" class="flex-shrink-0 flex items-center mb-4">
          <img
            src="/images/logo-inv.webp"
            alt="Logo White"
            class="h-8 grayscale brightness-200"
          />
        </a>
        <p class="text-white/70 text-sm leading-relaxed max-w-sm mb-6">
          Centro de Especialidades Médicas, brindando excelencia médica y
          atención humana de calidad internacional en el Estado de Nuevo León.
          Tu salud en las mejores manos. Autoridad médica al servicio de tu
          bienestar.
        </p>
        <div class="space-y-3 text-sm text-white/80">
          <p class="flex items-start">
            <i class="ph ph-map-pin mt-1 mr-3 text-brand-cyan text-lg"></i>
            <span
              >Carretera Nacional #6501,<br />La Estanzuela, Monterrey, N.L.</span
            >
          </p>
          <p class="flex items-center">
            <i class="ph ph-phone mr-3 text-brand-cyan text-lg"></i>
            <span>(81) 8155 5000</span>
          </p>
        </div>
      </div>

      <!-- Quick Links (7 cols combined) -->
      <div class="md:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-8">
        <div>
          <h4
            class="text-sm font-semibold tracking-wider text-white uppercase mb-4"
          >
            Cirugías
          </h4>
          <ul class="space-y-2">
            <li>
              <a
                href="/cirugias"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >Cirugía Bariátrica</a
              >
            </li>
            <li>
              <a
                href="/traumatologia"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >Traumatología</a
              >
            </li>
            <li>
              <a
                href="/neurologia"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >Neurología</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h4
            class="text-sm font-semibold tracking-wider text-white uppercase mb-4"
          >
            Maternidad
          </h4>
          <ul class="space-y-2">
            <li>
              <a
                href="/maternidad"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >Paquetes de Maternidad</a
              >
            </li>
            <li>
              <a
                href="/ucen"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >UCEN</a
              >
            </li>
            <li>
              <a
                href="/ginecologia"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >Ginecología</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h4
            class="text-sm font-semibold tracking-wider text-white uppercase mb-4"
          >
            Servicios Rápidos
          </h4>
          <ul class="space-y-2">
            <li>
              <a
                href="/check-ups"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >Check-ups Médicos</a
              >
            </li>
            <li>
              <a
                href="/laboratorio"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >Laboratorio</a
              >
            </li>
            <li>
              <a
                href="/directorio"
                class="text-sm text-white/70 hover:text-brand-cyan transition-colors"
                >Directorio Médico</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Middle Section: Trust Bar -->
    <div
      class="border-y border-white/10 py-8 mb-8 flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <p class="text-sm text-white/70 font-medium tracking-wide">
        Certificados por organizaciones nacionales e internacionales de salud.
      </p>
      <div
        class="flex flex-wrap items-center justify-center md:justify-end gap-8"
      >
        <img
          src="/images/cert-jci-seal.webp"
          alt="Sello JCI"
          class="grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 w-24 h-auto object-contain"
        />
        <img
          src="/images/cert-csg-sello.webp"
          alt="Sello CSG"
          class="grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 w-24 h-auto object-contain"
        />
      </div>
    </div>

    <!-- Bottom Section: Legal & Social -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div
        class="flex flex-col sm:flex-row items-center space-y-2 sm:space-y-0 sm:space-x-4 text-xs text-white/50"
      >
        <span
          >&copy; {new Date().getFullYear()} Centro de Especialidades Médicas. Todos
          los derechos reservados.</span
        >
        <span class="hidden sm:inline">|</span>
        <span class="text-white/40 font-medium"
          >Permiso COFEPRIS 243300201A0090</span
        >
        <span class="hidden sm:inline">|</span>
        <a href="/aviso-privacidad" class="hover:text-white transition-colors"
          >Aviso de Privacidad</a
        >
      </div>
      <div class="flex items-center space-x-6">
        <a
          href="https://facebook.com"
          aria-label="Facebook"
          class="text-white/50 hover:text-white transition-colors"
        >
          <i class="ph ph-facebook-logo text-2xl"></i>
        </a>
        <a
          href="https://instagram.com"
          aria-label="Instagram"
          class="text-white/50 hover:text-white transition-colors"
        >
          <i class="ph ph-instagram-logo text-2xl"></i>
        </a>
        <a
          href="https://linkedin.com"
          aria-label="LinkedIn"
          class="text-white/50 hover:text-white transition-colors"
        >
          <i class="ph ph-linkedin-logo text-2xl"></i>
        </a>
        <a
          href="https://twitter.com"
          aria-label="X (Twitter)"
          class="text-white/50 hover:text-white transition-colors"
        >
          <i class="ph ph-x-logo text-2xl"></i>
        </a>
      </div>
    </div>
  </div>
</footer>
