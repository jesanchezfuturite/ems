---
const pathname = Astro.url.pathname;
const isEmergencyPage = pathname === '/urgencias' || pathname === '/urgencias/';
---

<header class="sticky top-0 z-50 w-full border-b border-white/10 bg-white/70 backdrop-blur-md transition-all duration-300 py-4" id="main-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 flex items-center">
        <img
          class="h-10 w-auto"
          src="/images/logo.webp"
          alt="Centro de Especialidades Médicas Logo"
          width="150"
          height="40"
        />
      </a>

      <!-- Desktop Menu -->
      <nav class="hidden md:flex space-x-8 items-center">
        <div class="relative group">
          <button class="text-sm font-semibold hover:text-brand-blue transition-colors flex items-center gap-1 py-4">
            Servicios
            <i class="ph ph-caret-down text-xs transition-transform group-hover:rotate-180"></i>
          </button>
          
          <div class="absolute top-[80%] left-1/2 -translate-x-1/2 pt-4 opacity-0 translate-y-3 invisible group-hover:opacity-100 group-hover:translate-y-0 group-hover:visible transition-all duration-300 w-[350px] z-[100]">
            <div class="bg-gradient-to-b from-[#004b87] to-[#002f54] rounded-3xl p-6 shadow-2xl border border-[#00a3e0]/20 overflow-hidden flex flex-col">
              
              <h5 class="text-white/50 text-xs tracking-[0.2em] font-bold uppercase mb-4 pl-2">Diagnóstico y Prevención</h5>
              
              <nav class="flex flex-col gap-2">
                <a href="/cirugias" class="flex items-center gap-4 p-3 rounded-2xl group/item hover:bg-white/5 transition-colors">
                  <div class="bg-white/10 w-10 h-10 rounded-full flex justify-center items-center group-hover/item:shadow-[0_0_12px_#00a3e0] transition-all duration-300">
                    <i class="ph ph-activity text-[#00a3e0] text-xl"></i>
                  </div>
                  <span class="text-white font-medium group-hover/item:text-[#00a3e0] transition-colors">1. Cirugías</span>
                </a>

                <a href="/diagnostico" class="flex items-center gap-4 p-3 rounded-2xl group/item hover:bg-white/5 transition-colors">
                  <div class="bg-white/10 w-10 h-10 rounded-full flex justify-center items-center group-hover/item:shadow-[0_0_12px_#00a3e0] transition-all duration-300">
                    <i class="ph ph-flask text-[#00a3e0] text-xl"></i>
                  </div>
                  <span class="text-white font-medium group-hover/item:text-[#00a3e0] transition-colors">2. Laboratorio y Diagnóstico</span>
                </a>

                <a href="/checkups" class="flex items-center gap-4 p-3 rounded-2xl group/item hover:bg-white/5 transition-colors">
                  <div class="bg-white/10 w-10 h-10 rounded-full flex justify-center items-center group-hover/item:shadow-[0_0_12px_#00a3e0] transition-all duration-300">
                    <i class="ph ph-clipboard-text text-[#00a3e0] text-xl"></i>
                  </div>
                  <span class="text-white font-medium group-hover/item:text-[#00a3e0] transition-colors">3. Check-ups Preventivos</span>
                </a>
              </nav>

            </div>
          </div>
        </div>
        <a href="/especialidades" class="text-sm font-semibold hover:text-brand-blue transition-colors">Especialidades</a>
        <a href="/maternidad" class="text-sm font-semibold hover:text-brand-blue transition-colors">Maternidad</a>
        <a href="/directorio" class="text-sm font-semibold hover:text-brand-blue transition-colors">Directorio Médico</a>
        <a href="/blog" class="text-sm font-semibold hover:text-brand-blue transition-colors">Blog</a>
      </nav>

      <!-- Mobile Button -->
      <div class="flex items-center md:hidden">
        <button id="mobile-menu-btn" class="text-gray-500 hover:text-brand-blue focus:outline-none">
          <i class="ph ph-list text-3xl"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/90 backdrop-blur-md border-t border-gray-100 mt-4 absolute w-full left-0 shadow-xl top-full origin-top transition-all duration-300">
    <div class="px-4 pt-4 pb-6 space-y-2">
      <div class="mb-2">
        <p class="px-3 text-xs font-bold text-slate-400 tracking-wider uppercase mb-1">Servicios</p>
        <a href="/cirugias" class="block px-3 py-2 rounded-xl text-base font-medium text-slate-700 hover:text-brand-blue hover:bg-slate-50">Cirugías</a>
        <a href="/checkups" class="block px-3 py-2 rounded-xl text-base font-medium text-slate-700 hover:text-brand-blue hover:bg-slate-50">Check-ups Médicos</a>
      </div>
      <a href="/especialidades" class="block px-3 py-2 rounded-xl text-base font-medium text-slate-700 hover:text-brand-blue hover:bg-slate-50">Especialidades</a>
      <a href="/maternidad" class="block px-3 py-2 rounded-xl text-base font-medium text-slate-700 hover:text-brand-blue hover:bg-slate-50">Maternidad</a>
      <a href="/directorio" class="block px-3 py-2 rounded-xl text-base font-medium text-slate-700 hover:text-brand-blue hover:bg-slate-50">Directorio Médico</a>
      <a href="/blog" class="block px-3 py-2 rounded-xl text-base font-medium text-slate-700 hover:text-brand-blue hover:bg-slate-50">Blog</a>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Scroll header logic
    const header = document.querySelector('#main-header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('py-2', 'shadow-sm');
        header.classList.remove('py-4');
      } else {
        header.classList.add('py-4');
        header.classList.remove('py-2', 'shadow-sm');
      }
    });

    // Mobile menu logic
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if(btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  });
</script>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
</style>
