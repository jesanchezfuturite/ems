---
// src/components/Hero.astro
---

<section class="relative min-h-[85vh] flex items-center justify-start overflow-hidden bg-white">
  <!-- Video Background -->
  <div class="absolute inset-0 z-0">
    <video 
      class="w-full h-full object-cover object-center"
      autoplay 
      loop 
      muted 
      playsinline
    >
      <source src="/videos/cirugia.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Gradients & Overlays para legibilidad y transición suave -->
  <!-- 1. Degradado lateral izquierdo (Blanco a Transparente) para leer texto -->
  <div class="absolute inset-0 z-10 bg-gradient-to-r from-white via-white/80 to-transparent"></div>
  
  <!-- 2. Degradado inferior (Transparente a Blanco/Slate-50) para fusionar con la siguiente sección -->
  <div class="absolute inset-0 z-10 bg-gradient-to-b from-transparent via-white/20 to-slate-50"></div>

  <!-- Content -->
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-16 pb-24">
    <div class="max-w-3xl">
      <h1 class="hero-anm text-5xl sm:text-6xl lg:text-7xl font-black tracking-tighter text-brand-blue mb-6 leading-[1.1]">
        Tu salud merece la precisión de los <span class="text-brand-cyan">mejores especialistas</span>.
      </h1>
      <p class="hero-anm text-xl sm:text-2xl text-slate-700 mb-10 max-w-2xl font-light leading-relaxed">
        En el Centro de Especialidades Médicas, combinamos calidez humana con quirófanos de alta tecnología para tu pronta recuperación.
      </p>
      
      <div class="hero-anm flex flex-col sm:flex-row gap-4">
        <a href="/directorio" class="bg-brand-blue text-white px-8 py-4 rounded-full font-bold hover:bg-blue-900 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(30,58,138,0.5)] hover:shadow-[0_10px_40px_-5px_rgba(30,58,138,0.8)] hover:-translate-y-1 flex items-center justify-center group">
          Directorio Médico
          <i class="ph ph-arrow-right ml-2 group-hover:translate-x-1 transition-transform" aria-label="Ir a Directorio Médico"></i>
        </a>
        <a href="tel:+528100000000" class="bg-white text-slate-800 border border-slate-200 px-8 py-4 rounded-full font-bold hover:bg-slate-50 hover:border-slate-300 transition-all duration-300 shadow-sm hover:shadow-md flex items-center justify-center">
          <i class="ph ph-phone text-xl mr-2 text-brand-cyan" aria-label="Teléfono"></i>
          81 0000 0000
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Optional: Masking para un recorte curvilíneo inferior si se desea en el contenedor de bg */
  /* Lo dejamos comentado ya que el gradient-to-b hace un fade suave hacia slate-50 que es muy elegante */
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap !== 'undefined') {
      const tl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1.2 } });
      
      // Animación de los elementos de texto (fade in y slide up)
      tl.fromTo(".hero-anm", 
        { y: 40, opacity: 0 }, 
        { y: 0, opacity: 1, stagger: 0.15, delay: 0.2 }
      );
    }
  });
</script>
