---
// src/components/Hero.astro
---

<section class="relative min-h-[85vh] flex items-center justify-start overflow-hidden bg-white pt-16" id="hero-section">
  <!-- Video Background with Seamless Mask -->
  <div class="absolute inset-0 z-0 seamless-mask">
    <video 
      class="w-full h-full object-cover object-center hero-parallax-video scale-110"
      autoplay 
      loop 
      muted 
      playsinline
    >
      <source src="/videos/cirugia.mp4" type="video/mp4" />
    </video>
    <!-- Overlay sutil para garantizar contraste del texto azul -->
    <div class="absolute inset-0 bg-white/40 backdrop-blur-sm"></div>
    <!-- Gradiente que refuerza la fusión hacia abajo -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/80 to-white"></div>
  </div>

  <!-- Content -->
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-16 pb-24">
    <div class="max-w-3xl">
      <h1 class="hero-anm text-5xl sm:text-6xl lg:text-7xl font-black tracking-tighter text-[#004b87] mb-6 leading-[1.1]">
        Centro de Especialidades Médicas
      </h1>
      <p class="hero-anm text-xl sm:text-2xl text-slate-700 mb-10 max-w-2xl font-medium leading-relaxed">
        Conectamos a pacientes con médicos especialistas certificados para diagnóstico preciso y tratamiento integral en más de 40 especialidades médicas.
      </p>
      
      <div class="hero-anm flex flex-col sm:flex-row gap-4">
        <a href="/directorio" class="bg-[#004b87] text-white px-8 py-4 rounded-full font-bold hover:bg-blue-900 transition-all duration-300 shadow-xl hover:-translate-y-1 flex items-center justify-center group">
          Directorio Médico
          <i class="ph ph-arrow-right ml-2 group-hover:translate-x-1 transition-transform" aria-label="Ir a Directorio Médico"></i>
        </a>
        <a href="tel:+528181555000" class="glass-card text-slate-800 px-8 py-4 rounded-full font-bold hover:bg-white transition-all duration-300 shadow-lg flex items-center justify-center">
          <i class="ph ph-phone text-xl mr-2 text-[#00a3e0]" aria-label="Teléfono"></i>
          81 8155 5000
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .seamless-mask {
    -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap !== 'undefined') {
      const tl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1.2 } });
      
      // Animación de los elementos de texto (fade in upward)
      tl.fromTo(".hero-anm", 
        { y: 50, opacity: 0 }, 
        { y: 0, opacity: 1, stagger: 0.15, delay: 0.1 }
      );

      // Efecto Parallax muy sutil en el video
      if (typeof ScrollTrigger !== 'undefined') {
        gsap.to(".hero-parallax-video", {
          yPercent: 15,
          ease: "none",
          scrollTrigger: {
            trigger: "#hero-section",
            start: "top top",
            end: "bottom top",
            scrub: true
          }
        });
      }
    }
  });
</script>
