---
import Layout from '../layouts/Layout.astro';

// AEO: JSON-LD FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuál es la diferencia entre parto natural y cesárea en su hospital?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El parto natural es un proceso fisiológico respetado con mínima intervención, mientras que la cesárea es un procedimiento quirúrgico mayor. En nuestro centro, ambas opciones cuentan con monitoreo avanzado, pero la cesárea incluye dos noches de hospitalización y uso de quirófano estéril."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué debo llevar al hospital para el día del parto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Se recomienda llevar documentos médicos, estudios previos, ropa cómoda, artículos personales y lo necesario para el recién nacido."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué incluye un paquete de maternidad?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Incluye estancia hospitalaria, atención médica especializada, cuidados neonatales y servicios adicionales según el tipo de parto."
      }
    },
    {
      "@type": "Question",
      "name": "¿Pueden acompañarme durante el parto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, nuestras salas LPR (Labor, Parto y Recuperación) están diseñadas para que un acompañante de tu elección esté contigo en todo momento, fomentando el apego y brindando apoyo emocional."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si ocurre una emergencia durante el parto natural?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Contamos con protocolos de emergencia inmediatos. Nuestros quirófanos están disponibles 24/7 y la transición de parto natural a cesárea de emergencia se realiza en minutos con un equipo multidisciplinario listo para actuar."
      }
    }
  ]
};

// Fetch Especialistas de Ginecología (ID 18)
let gineDoctors = [];
try {
  const res = await fetch('https://administrador.especialidadesmedicassur.com.mx/api/directorio-medico/search?especialidad_id=18&per_page=3');
  const data = await res.json();
  if (data && data.data && data.data.data) {
    gineDoctors = data.data.data;
  } else if (data && data.data) {
    gineDoctors = Array.isArray(data.data) ? data.data : [];
  } else if (Array.isArray(data)) {
    gineDoctors = data.slice(0, 3);
  }
} catch (error) {
  console.error("Error fetching ginecology doctors:", error);
}

// Helper para mayúsculas
const toTitleCase = (str) => {
  if (!str) return '';
  const minors = ['y', 'de', 'del', 'el', 'la', 'los', 'las', 'en'];
  return str.toLowerCase().split(' ').map((word, index) => {
    if (index > 0 && minors.includes(word)) return word;
    return word.charAt(0).toUpperCase() + word.slice(1);
  }).join(' ');
};
---

<Layout 
  title="Centro de Maternidad en Monterrey | Especialistas en Embarazo"
  description="Atención integral para embarazo y parto con ginecólogos certificados. Clínicas seguras, UCIN Nivel III y certificación JCI. Conoce el Centro de Maternidad en Monterrey."
>
  <!-- Preload Font for Performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">

  <style>
    /* Aplicando la tipografía solicitada a todo el scope de esta página */
    .font-jakarta {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    /* Estilos específicos si se requiere forzar el color de base */
    .text-primary-blue { color: #004b87; }
    .bg-primary-blue { background-color: #004b87; }
    .text-surgical-cyan { color: #00a3e0; }
    .bg-surgical-cyan { background-color: #00a3e0; }
  </style>

  <!-- Inject JSON-LD para SEO (AEO) -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="font-jakarta text-slate-700 bg-slate-50 selection:bg-[#00a3e0] selection:text-white">
    
    <!-- 1. HERO SECTION -->
    <section class="relative w-full min-h-[90vh] flex items-center bg-white overflow-hidden py-20 lg:py-32">
      <!-- Decoración de fondo suave -->
      <div class="absolute inset-0 z-0 pointer-events-none opacity-40 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-100 via-transparent to-transparent"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Text Content -->
          <div class="hero-content flex flex-col justify-center text-center lg:text-left order-2 lg:order-1">
            <div class="inline-flex items-center self-center lg:self-start px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-[#004b87] text-sm font-semibold tracking-wide mb-6">
              <span class="w-2 h-2 rounded-full bg-[#00a3e0] mr-2"></span>
              Líderes en Maternidad
            </div>
            <!-- Accionable 1: H1 SEO Optimizado -->
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-[#004b87] mb-6 tracking-tight leading-[1.1]">
              Centro de Maternidad en Monterrey
            </h1>
            <p class="text-lg md:text-xl text-slate-600 mb-10 max-w-2xl mx-auto lg:mx-0 font-medium leading-relaxed">
              Atención integral para embarazo y parto con ginecólogos certificados y tecnología especializada. Tu bienestar y el de tu bebé son nuestra absoluta prioridad.
            </p>
            <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
              <a href="#paquetes" class="w-full sm:w-auto px-8 py-4 bg-[#004b87] text-white text-lg font-bold rounded-xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20 text-center">
                Ver Paquetes de Parto
              </a>
              <a href="/contacto" class="w-full sm:w-auto px-8 py-4 glass-card text-[#004b87] text-lg font-bold hover:bg-white/90 transition-all flex items-center justify-center">
                Agenda tu Cita Médica
              </a>
            </div>
          </div>

          <!-- Hero Image con Fade/Mask Effect -->
          <div class="hero-image-container relative order-1 lg:order-2">
            <div class="relative w-full max-w-lg mx-auto aspect-[4/5] lg:aspect-square">
              <!-- Mask image para crear un borde suave difuminado -->
              <div class="absolute inset-0 rounded-[3rem] overflow-hidden bg-gradient-to-tr from-blue-50 to-white" style="mask-image: radial-gradient(white, black); -webkit-mask-image: -webkit-radial-gradient(white, black);">
                <img 
                  src="/images/momBaby.webp" 
                  alt="Madre y bebé en Centro de Maternidad en Monterrey" 
                  class="w-full h-full object-cover object-center hero-parallax-img scale-105"
                  onerror="this.src='https://images.unsplash.com/photo-1544281679-450f75e2eb22?q=80&w=2670&auto=format&fit=crop'"
                />
                <!-- Gradiente superpuesto sutil -->
                <div class="absolute inset-0 bg-gradient-to-t from-[#004b87]/30 to-transparent"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. SEGURIDAD PRIMERO (E-E-A-T & AEO) -->
    <section class="py-24 bg-slate-50 relative z-20 shadow-[0_-20px_40px_-20px_rgba(0,0,0,0.05)]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 max-w-4xl mx-auto safety-header">
          <h2 class="text-3xl md:text-5xl font-extrabold text-[#004b87] mb-4">Certificación internacional para tu seguridad (JCI)</h2>
          <p class="text-slate-600 text-lg md:text-xl">Respaldados por la Joint Commission International (JCI), garantizamos los más altos estándares globales en atención médica materno-infantil.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          <!-- AEO Snippet LPR -->
          <div class="glass-card p-10 hover:-translate-y-1 transition-transform duration-300 safety-card">
            <div class="flex items-center mb-6">
              <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-md mr-4">
                <i class="ph ph-house-line text-3xl text-[#00a3e0]"></i>
              </div>
              <h3 class="text-2xl font-extrabold text-[#004b87]">¿Qué es una sala LPR?</h3>
            </div>
            <p class="text-slate-600 leading-relaxed text-lg">
              Una sala <strong>LPR (Labor, Parto y Recuperación)</strong> es una habitación privada y acondicionada donde la madre experimenta todo el proceso de dar a luz sin necesidad de ser trasladada a diferentes áreas, reduciendo el estrés y fomentando el apego inmediato en un entorno familiar y seguro.
            </p>
          </div>

          <!-- AEO Snippet UCIN -->
          <div class="glass-card p-10 hover:-translate-y-1 transition-transform duration-300 safety-card">
            <div class="flex items-center mb-6">
              <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-md mr-4">
                <i class="ph ph-baby text-3xl text-[#00a3e0]"></i>
              </div>
              <h3 class="text-2xl font-extrabold text-[#004b87]">UCIN Nivel III</h3>
            </div>
            <p class="text-slate-600 leading-relaxed text-lg">
              Nuestra <strong>Unidad de Cuidados Intensivos Neonatales (UCIN) de Nivel III</strong> es un beneficio directo para tu bebé: significa que contamos con neonatólogos 24/7 y ventilación mecánica avanzada, listos para resolver desde complicaciones menores hasta atención crítica compleja al instante.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. ESPECIALISTAS (E-E-A-T) -->
    <section class="py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-5xl font-extrabold text-[#004b87] mb-6">Equipo médico para embarazo y parto</h2>
        <p class="text-slate-600 text-lg md:text-xl max-w-2xl mx-auto mb-16">
          Nuestros ginecólogos y obstetras están avalados por el Consejo Mexicano de Ginecología y Obstetricia.
        </p>

        <!-- Grid de Médicos -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12" id="especialistas-grid">
          {gineDoctors.length > 0 ? gineDoctors.map((doc) => (
            <div class="glass-card p-8 border border-slate-100 text-center doctor-card">
              <div class="w-32 h-32 mx-auto rounded-full bg-slate-200 overflow-hidden mb-6 border-4 border-white shadow-lg">
                <img src={doc.foto || "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%23f1f5f9' width='100' height='100'/><path fill='%23cbd5e1' d='M50 50c11.046 0 20-8.954 20-20s-8.954-20-20-20-20 8.954-20 20 8.954 20 20 20zm0 10c-13.314 0-40 6.671-40 20v10h80V80c0-13.329-26.686-20-40-20z'/></svg>"} alt={`Dr. ${toTitleCase(doc.nombre)}`} loading="lazy" class="w-full h-full object-cover border border-slate-100" />
              </div>
              <h3 class="text-xl font-extrabold text-[#004b87] mb-1 line-clamp-1" title={toTitleCase(doc.nombre)}>{toTitleCase(doc.nombre)}</h3>
              <p class="text-slate-500 font-medium mb-4 line-clamp-1">{doc.especialidad || 'Ginecoyobstetricia'}</p>
              <div class="inline-flex items-center justify-center px-4 py-2 bg-blue-50 text-[#004b87] rounded-lg text-sm font-bold w-full">
                <i class="ph-fill ph-seal-check text-[#00a3e0] mr-2"></i> Certificado Especialista
              </div>
            </div>
          )) : (
            <div class="col-span-full text-center text-slate-500 py-8">
              No se pudieron cargar los especialistas en este momento.
            </div>
          )}
        </div>

        <a href="/directorio?especialidad=ginecologia-y-obstetricia" class="inline-flex items-center justify-center px-8 py-4 bg-[#00a3e0] text-white text-lg font-bold rounded-xl hover:bg-cyan-500 transition-colors shadow-lg shadow-cyan-500/30">
          Conoce a nuestros especialistas y agenda tu cita
        </a>
      </div>
    </section>

    <!-- 4. PAQUETES AEO -->
    <section id="paquetes" class="py-24 bg-[#004b87] relative overflow-hidden rounded-t-[3rem] lg:rounded-t-[5rem]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16 max-w-3xl mx-auto">
          <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">Planes de Maternidad Transparentes</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto items-stretch package-wrapper">
          <!-- Paquete Natural -->
          <div class="glass-card !bg-white p-10 md:p-14 relative flex flex-col h-full transform transition hover:scale-[1.02] duration-300">
            <h3 class="text-2xl md:text-3xl font-extrabold text-[#004b87] mb-4">¿Qué incluye el paquete de parto natural?</h3>
            <ul class="space-y-4 flex-grow mb-8 mt-4">
              <li class="flex items-start">
                <i class="ph-fill ph-check-circle text-[#00a3e0] text-2xl mr-3 mt-0.5 flex-shrink-0"></i>
                <span class="text-slate-700 font-medium leading-tight">Estancia en Habitación Suite LPR</span>
              </li>
              <li class="flex items-start">
                <i class="ph-fill ph-check-circle text-[#00a3e0] text-2xl mr-3 mt-0.5 flex-shrink-0"></i>
                <span class="text-slate-700 font-medium leading-tight">Uso e insumos básicos de sala de labor</span>
              </li>
              <li class="flex items-start">
                <i class="ph-fill ph-check-circle text-[#00a3e0] text-2xl mr-3 mt-0.5 flex-shrink-0"></i>
                <span class="text-slate-700 font-medium leading-tight">Enfermería neonatal en cuneros 24 hrs</span>
              </li>
              <li class="flex items-start">
                <i class="ph-fill ph-check-circle text-[#00a3e0] text-2xl mr-3 mt-0.5 flex-shrink-0"></i>
                <span class="text-slate-700 font-medium leading-tight">Vacunas aplicadas al nacer (BCG y Hep. B)</span>
              </li>
            </ul>
            <a href="/contacto" class="w-full mt-auto block text-center py-4 px-6 rounded-xl border-2 border-[#004b87] text-[#004b87] font-bold hover:bg-blue-50 transition-colors">Agendar Cita de Valoración</a>
          </div>

          <!-- Paquete Cesárea -->
          <div class="glass-card !bg-white p-10 md:p-14 relative flex flex-col h-full transform transition hover:scale-[1.02] duration-300 border-4 !border-[#00a3e0]">
            <div class="absolute -top-5 left-1/2 transform -translate-x-1/2 bg-[#00a3e0] text-white px-6 py-2 rounded-full font-bold text-sm tracking-widest uppercase shadow-xl flex items-center whitespace-nowrap">
              <i class="ph-fill ph-star mr-2 text-white"></i> Opción Segura
            </div>
            
            <h3 class="text-2xl md:text-3xl font-extrabold text-[#004b87] mb-4">¿Qué incluye el paquete de cesárea?</h3>
            <ul class="space-y-4 flex-grow mb-8 mt-4">
              <li class="flex items-start">
                <i class="ph-fill ph-check-circle text-[#00a3e0] text-2xl mr-3 mt-0.5 flex-shrink-0"></i>
                <span class="text-slate-700 font-medium leading-tight">2 Noches en Habitación Suite Privada</span>
              </li>
              <li class="flex items-start">
                <i class="ph-fill ph-check-circle text-[#00a3e0] text-2xl mr-3 mt-0.5 flex-shrink-0"></i>
                <span class="text-slate-700 font-medium leading-tight">Uso de Quirófano estéril e instrumental</span>
              </li>
              <li class="flex items-start">
                <i class="ph-fill ph-check-circle text-[#00a3e0] text-2xl mr-3 mt-0.5 flex-shrink-0"></i>
                <span class="text-slate-700 font-medium leading-tight">Sala de recuperación postanestésica</span>
              </li>
              <li class="flex items-start">
                <i class="ph-fill ph-check-circle text-[#00a3e0] text-2xl mr-3 mt-0.5 flex-shrink-0"></i>
                <span class="text-slate-700 font-medium leading-tight">Enfermería neonatal en cuneros 48 hrs</span>
              </li>
            </ul>
            <a href="/contacto" class="w-full mt-auto block text-center py-4 px-6 rounded-xl bg-[#00a3e0] text-white font-bold hover:bg-cyan-500 transition-colors shadow-lg">Agendar Cita de Valoración</a>
          </div>
        </div>

        <!-- Notas de Transparencia & Claridad AEO -->
        <div class="mt-12 max-w-5xl mx-auto glass-card !bg-white/10 p-8 border-none opacity-95">
          <div class="grid md:grid-cols-2 gap-8 text-white text-sm">
            <div>
              <h4 class="font-extrabold flex items-center mb-2 text-lg"><i class="ph ph-info text-2xl mr-2 text-[#00a3e0]"></i> Transparencia Médica</h4>
              <p class="leading-relaxed opacity-90">Tu seguridad es 24/7. En caso de una complicación real durante un intento de parto natural, el equipo médico está preparado para realizar una <strong>transición inmediata a cesárea de emergencia</strong>, ajustando los lineamientos del paquete hacia los insumos quirúrgicos sin demoras.</p>
            </div>
            <div>
              <h4 class="font-extrabold flex items-center mb-2 text-lg"><i class="ph ph-ear text-2xl mr-2 text-[#00a3e0]"></i> Tamiz Auditivo vs. Metabólico</h4>
              <p class="leading-relaxed opacity-90">Ambos paquetes consideran opciones de tamizaje. El <strong>tamiz auditivo</strong> evalúa precozmente la capacidad de audición del recién nacido, mientras que el <strong>tamiz metabólico</strong> (una pequeña punción en el talón) detecta alteraciones bioquímicas en los primeros días de vida.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. PRUEBA SOCIAL -->
    <section class="py-24 bg-slate-50 border-b border-slate-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-5xl font-extrabold text-[#004b87] mb-12">Testimonios de nuestras pacientes</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="glass-card p-10 text-left testimonial-card">
            <div class="flex text-yellow-400 mb-4 text-xl">
              <i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i>
            </div>
            <p class="text-slate-600 font-medium italic mb-6">"El trato de las enfermeras y la doctora Ana en la sala LPR hizo que mi parto natural fuera mágico. Nunca me sentí sola, la seguridad de estar ahí me dio mucha paz."</p>
            <h4 class="font-bold text-[#004b87]">— Mariana G.</h4>
          </div>
          
          <div class="glass-card p-10 text-left testimonial-card">
             <div class="flex text-yellow-400 mb-4 text-xl">
              <i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i>
            </div>
            <p class="text-slate-600 font-medium italic mb-6">"Mi bebé tuvo que ir a la UCIN por unas complicaciones. Saber que el área estaba a unos pasos y ver el profesionalismo de los neonatólogos nos salvó del pánico."</p>
            <h4 class="font-bold text-[#004b87]">— Lucía Y.</h4>
          </div>

          <div class="glass-card p-10 text-left testimonial-card">
             <div class="flex text-yellow-400 mb-4 text-xl">
              <i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i>
            </div>
            <p class="text-slate-600 font-medium italic mb-6">"Tuve una cesárea programada. El quirófano estaba impecable, sentí el respaldo por ser un hospital certificado JCI. La recuperación en la suite fue súper cómoda."</p>
            <h4 class="font-bold text-[#004b87]">— Fernanda R.</h4>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. FAQ AVANZADA -->
    <section class="py-24 bg-white relative">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 faq-header">
          <h2 class="text-3xl md:text-5xl font-black text-[#004b87] tracking-tight mb-4">Preguntas Frecuentes</h2>
          <p class="text-slate-600 text-lg md:text-xl font-medium">Respuestas rápidas para facilitarte el acceso a tu atención médica.</p>
        </div>
        
        <div class="space-y-6">
          <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] border-l-4 border-l-transparent hover:border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
            <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
              ¿Cuál es la diferencia entre parto natural y cesárea en su hospital?
              <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
            </summary>
            <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4 pr-8">
              El parto natural es un proceso fisiológico respetado con mínima intervención, mientras que la cesárea es un procedimiento quirúrgico mayor. En nuestro centro, ambas opciones cuentan con monitoreo avanzado, pero la cesárea incluye dos noches de hospitalización y uso de quirófano estéril.
            </div>
          </details>

          <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] border-l-4 border-l-transparent hover:border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
            <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
              ¿Qué debo llevar al hospital para el día del parto?
              <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
            </summary>
            <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4 pr-8">
              Se recomienda llevar documentos médicos, estudios previos, ropa cómoda, artículos personales y lo necesario para el recién nacido.
            </div>
          </details>

