    document.addEventListener('DOMContentLoaded', () => {
      if (typeof window.gsap !== 'undefined' && typeof window.ScrollTrigger !== 'undefined') {
        const { gsap, ScrollTrigger } = window;
        gsap.registerPlugin(ScrollTrigger);

        // Hero Reveal
        const heroTl = gsap.timeline();
        heroTl.from(".hero-content > *", { y: 30, opacity: 0, duration: 0.8, stagger: 0.15, ease: "power3.out" })
              .from(".hero-image-container", { scale: 0.95, opacity: 0, duration: 1.2, ease: "expo.out" }, "-=0.6");

        // Parallax simple hero
        gsap.to(".hero-parallax-img", {
          yPercent: 10,
          ease: "none",
          scrollTrigger: { trigger: ".hero-image-container", start: "top bottom", end: "bottom top", scrub: true } 
        });

        // Seguridad Reveal
        gsap.from(".safety-card", {
          scrollTrigger: { trigger: ".safety-header", start: "top 80%" },
          y: 40, opacity: 0, duration: 0.8, stagger: 0.2, ease: "back.out(1.5)"
        });

        // Especialistas (Deshabilitado por renderizado inconsistente)
