  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      // Verificar si GSAP está cargado
      if (typeof window.gsap !== "undefined" && window.ScrollTrigger) {
        const gsap = window.gsap;
        const ScrollTrigger = window.ScrollTrigger;
        
        gsap.registerPlugin(ScrollTrigger);

        setTimeout(() => {

        // Animaciones de Entrada (Hero)
        gsap.from(".hero-reveal > *", {
          y: 30,
          opacity: 0,
          stagger: 0.15,
          duration: 1,
          ease: "power3.out",
          delay: 0.2
        });

        // Stagger para grid de síntomas
        gsap.from(".symptom-card", {
          scrollTrigger: {
            trigger: ".symptom-grid",
            start: "top 80%",
          },
          y: 40,
          opacity: 0,
          stagger: 0.1,
          duration: 0.8,
          ease: "back.out(1.7)"
        });

        // Stagger para enfermedades (Bento)
        gsap.from(".disease-card", {
          scrollTrigger: {
            trigger: ".disease-grid",
            start: "top 90%",
          },
          scale: 0.95,
          opacity: 0,
          stagger: 0.15,
          duration: 0.8,
          ease: "power3.out",
          clearProps: "all"
        });

        // Animación de pasos de atención (Stepper)
        gsap.from(".process-step", {
          scrollTrigger: {
            trigger: ".process-grid",
            start: "top 80%",
          },
          y: 30,
          opacity: 0,
          stagger: 0.2,
          duration: 0.8,
          ease: "power2.out"
        });

        // Especialistas Hover
        gsap.from(".specialist-card", {
          scrollTrigger: {
            trigger: ".specialist-card",
            start: "top 85%",
          },
          y: 40,
          opacity: 0,
          stagger: 0.2,
          duration: 0.8,
          ease: "power3.out"
        });
        }, 100);
      }

      // Observador para Mobile CTA
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const ctaBtn = document.getElementById("mobile-cta");
          if (ctaBtn) {
            if (!entry.isIntersecting && window.scrollY > 300) {
              ctaBtn.classList.remove("translate-y-full");
            } else {
              ctaBtn.classList.add("translate-y-full");
            }
          }
        });
      }, {
        rootMargin: "0px",
        threshold: 0.1
      });

      const heroSection = document.querySelector("header");
      if (heroSection) {
        observer.observe(heroSection);
      }
    });
  </script>

