---
import Layout from '../layouts/Layout.astro';

// AEO: JSON-LD FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo agendar una cita médica en el directorio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Puedes agendar una cita rápida haciendo clic en el botón 'Agendar Cita' de cualquier especialista en nuestro directorio, el cual te redirigirá a nuestras opciones de contacto inmediato."
      }
    },
    {
      "@type": "Question",
      "name": "¿Aceptan seguros de gastos médicos mayores?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, nuestros especialistas y las instalaciones de Centro de Especialidades Médicas Sur están afiliados a las principales aseguradoras (GNP, AXA, MetLife, Seguros Monterrey, entre otras)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo elegir al especialista médico adecuado para mí?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Recomendamos usar nuestro buscador por especialidad o padecimiento. También puedes entrar al perfil individual de cada médico para conocer su formación académica, certificaciones y subespecialidades clínicas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Dónde están ubicados los consultorios médicos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nuestros especialistas consultan dentro del Hospital Christus Sur, ubicado en la Carretera Nacional, garantizando acceso inmediato a urgencias y tecnología médica de última generación."
      }
    }
  ]
};
---

<Layout 
  title="Directorio Médico Especializado | Centro de Especialidades Médicas Sur"
  description="Conecta con médicos especialistas en Monterrey. Ginecólogos, pediatras, traumatólogos y más, certificados con los más altos estándares médicos y humanos."
>
  <!-- Inyección JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style is:global>
    .text-brand-blue { color: #004b87; }
    .bg-brand-blue { background-color: #004b87; }
    .border-brand-blue { border-color: #004b87; }
    .text-brand-cyan { color: #00a3e0; }
    .bg-brand-cyan { background-color: #00a3e0; }
    .border-brand-cyan { border-color: #00a3e0; }

    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    .skeleton-shimmer {
      background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }
  </style>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-slate-50 to-[#00a3e0]/5 pt-20 pb-16 overflow-hidden relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h1 class="text-4xl lg:text-6xl font-extrabold text-brand-blue mb-6 tracking-tight font-jakarta">Directorio Médico Especializado</h1>
        <p class="text-xl text-slate-600 font-jakarta leading-relaxed max-w-2xl mx-auto">
          Conecta con los mejores médicos del norte del país, certificados clínica y humanamente para tu cuidado integral.
        </p>
      </div>

      <!-- Barra Unificada Avanzada -->
      <div class="max-w-4xl mx-auto">
        <div class="glass-card rounded-[2rem] p-3 mb-6 transition-all focus-within:ring-4 focus-within:ring-brand-cyan/20 focus-within:bg-white relative z-20">
          <div class="grid grid-cols-1 md:grid-cols-[1.2fr_auto_1.2fr_auto] items-center gap-3">
            
            <!-- 1. Input -->
            <div class="relative flex items-center h-full group">
              <i class="ph ph-magnifying-glass absolute left-5 text-brand-cyan text-2xl z-10 pointer-events-none group-focus-within:text-brand-blue transition-colors"></i>
              <input 
                type="text" 
                id="search-input"
                class="w-full h-14 bg-slate-50/50 md:bg-transparent border-0 pl-14 pr-4 text-slate-800 placeholder-slate-400 focus:outline-none text-lg rounded-2xl md:rounded-none font-jakarta focus:bg-transparent transition-colors"
                placeholder="Nombre del médico..."
                autocomplete="off"
              />
            </div>
            
            <!-- Divisor -->
            <div class="hidden md:block w-px h-10 bg-slate-200/80 mx-2"></div>

            <!-- 2. Select Especialidad -->
            <div class="relative flex items-center group">
              <i class="ph ph-stethoscope absolute left-5 text-brand-cyan text-2xl z-10 pointer-events-none group-focus-within:text-brand-blue transition-colors"></i>
              <select id="specialty-select" class="appearance-none w-full h-14 bg-slate-50/50 md:bg-transparent border-0 pl-14 pr-10 text-slate-700 font-bold focus:outline-none text-lg cursor-pointer rounded-2xl md:rounded-none font-jakarta truncate">
                <option value="">Buscar por especialidad</option>
                <!-- JS Inject -->
              </select>
              <i class="ph ph-caret-down absolute right-5 text-slate-400 text-lg pointer-events-none group-focus-within:-rotate-180 transition-transform duration-300"></i>
            </div>

            <!-- 3. Botón Buscar -->
            <button id="search-btn" class="bg-brand-blue text-white px-10 h-14 rounded-2xl font-bold hover:bg-blue-900 focus:ring-4 focus:ring-brand-blue/30 transform hover:scale-[1.02] active:scale-95 transition-all duration-300 text-lg flex items-center justify-center w-full shadow-lg shadow-brand-blue/20 cursor-pointer">
              Buscar <i class="ph ph-arrow-right ml-2 text-xl"></i>
            </button>
            
          </div>
        </div>

        <!-- Quick Filters -->
        <div class="px-2 lg:px-4 flex flex-col sm:flex-row sm:items-center">
          <p class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-3 sm:mb-0 sm:mr-4 flex-shrink-0 font-jakarta">Sugerencias:</p>
          <div class="flex flex-wrap items-center gap-2" id="quick-filters">
            <div class="h-8 w-24 bg-brand-cyan/10 rounded-full animate-pulse"></div>
            <div class="h-8 w-32 bg-brand-cyan/10 rounded-full animate-pulse"></div>
            <div class="h-8 w-28 bg-brand-cyan/10 rounded-full animate-pulse"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feedback UI (Count) -->
  <div class="w-full bg-white border-b border-slate-100 py-3 shadow-sm relative z-10">
    <p id="results-count" class="text-center text-sm font-bold text-brand-cyan uppercase tracking-widest font-jakarta transition-opacity">Cargando directorio...</p>
  </div>

  <!-- Results Grid Section -->
  <section class="py-16 bg-[#f8fafc] min-h-[50vh] relative">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.03]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Doctor Cards -->
      <div id="doctors-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
      
      <!-- Empty State -->
      <div id="empty-state" class="hidden max-w-lg mx-auto text-center py-20 px-4">
        <div class="bg-white w-24 h-24 mx-auto rounded-full flex items-center justify-center mb-6 text-slate-300 shadow-sm border border-slate-100">
          <i class="ph ph-user-list text-5xl"></i>
        </div>
        <h3 class="text-2xl font-bold text-brand-blue mb-3 font-jakarta">Sin resultados</h3>
        <p class="text-slate-500 mb-8 max-w-sm mx-auto text-lg leading-relaxed font-jakarta">
          No encontramos especialistas que coincidan. Intente modificar su búsqueda.
        </p>
      </div>

      <!-- Load More Button -->
      <div id="load-more-container" class="hidden text-center mt-16 mb-8">
        <button id="load-more-btn" class="px-10 py-4 bg-white border-2 border-brand-cyan text-brand-cyan font-bold rounded-full hover:bg-brand-cyan hover:text-white transition-all shadow-md inline-flex items-center group font-jakarta text-lg cursor-pointer">
          Mostrar más especialistas <i class="ph ph-arrow-circle-down ml-3 text-2xl group-hover:translate-y-1 transition-transform"></i>
        </button>
      </div>
    </div>
  </section>

  <!-- Accionable 2: Cross-Selling Especialidades -->
  <section class="py-20 bg-brand-blue relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-brand-blue to-blue-900"></div>
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/diagnostic.png')]"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6 font-jakarta">La medicina a tu alcance</h2>
      <p class="text-xl text-blue-100 mb-12 max-w-3xl mx-auto leading-relaxed font-jakarta">Conoce más sobre nuestras clínicas especializadas y descubre cómo nuestro enfoque multidisciplinario protege tu bienestar.</p>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10 action-grid font-jakarta">
        <a href="/especialidades" class="bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 p-6 rounded-3xl transition-all duration-300 text-white flex flex-col items-center group">
          <i class="ph ph-baby text-4xl mb-3 text-brand-cyan group-hover:scale-110 transition-transform"></i>
          <span class="font-bold text-sm tracking-wide">Maternidad</span>
        </a>
        <a href="/especialidades" class="bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 p-6 rounded-3xl transition-all duration-300 text-white flex flex-col items-center group">
          <i class="ph ph-heartbeat text-4xl mb-3 text-brand-cyan group-hover:scale-110 transition-transform"></i>
          <span class="font-bold text-sm tracking-wide">Cardiología</span>
        </a>
        <a href="/especialidades" class="bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 p-6 rounded-3xl transition-all duration-300 text-white flex flex-col items-center group">
          <i class="ph ph-bone text-4xl mb-3 text-brand-cyan group-hover:scale-110 transition-transform"></i>
          <span class="font-bold text-sm tracking-wide">Ortopedia</span>
        </a>
        <a href="/especialidades" class="bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 p-6 rounded-3xl transition-all duration-300 text-white flex flex-col items-center group">
          <i class="ph ph-first-aid text-4xl mb-3 text-brand-cyan group-hover:scale-110 transition-transform"></i>
          <span class="font-bold text-sm tracking-wide">Urgencias</span>
        </a>
      </div>
      <a href="/especialidades" class="inline-flex py-4 px-8 bg-brand-cyan hover:bg-cyan-400 text-white rounded-full font-bold text-lg shadow-lg shadow-brand-cyan/30 transition-colors font-jakarta">
        Explorar Especialidades
      </a>
    </div>
  </section>

  <!-- Accionable 1: Sección FAQ -->
  <section class="py-24 bg-white font-jakarta relative border-t border-slate-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 faq-header">
        <h2 class="text-3xl md:text-5xl font-black text-[#004b87] tracking-tight mb-4">Preguntas Frecuentes</h2>
        <p class="text-slate-600 text-lg md:text-xl font-medium">Respuestas rápidas para facilitarte el acceso a tu atención médica.</p>
      </div>
      
      <div class="space-y-6 faq-items">
        {faqSchema.mainEntity.map((faq) => (
          <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] border-l-4 border-l-transparent hover:border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
            <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
              {faq.name}
              <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
            </summary>
            <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4 pr-8">
              {faq.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- JS Engine Logics -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', async () => {
      const grid = document.getElementById('doctors-grid');
      const searchInput = document.getElementById('search-input');
      const specialtySelect = document.getElementById('specialty-select');
      const searchBtn = document.getElementById('search-btn');
      const emptyState = document.getElementById('empty-state');
      const countEl = document.getElementById('results-count');
      const quickFiltersContainer = document.getElementById('quick-filters');
      const loadMoreContainer = document.getElementById('load-more-container');
      const loadMoreBtn = document.getElementById('load-more-btn');

      let currentPage = 1;
      let debounceTimer;
      const svgFallback = `data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='100%' height='100%' viewBox='0 0 100 100'><rect fill='%23f8fafc' width='100' height='100'/><path fill='%23cbd5e1' d='M50 50c11.046 0 20-8.954 20-20s-8.954-20-20-20-20 8.954-20 20 8.954 20 20 20zm0 10c-13.314 0-40 6.671-40 20v10h80V80c0-13.329-26.686-20-40-20z'/></svg>`;

      // Helpers
      const renderSkeletons = (count = 6, cleanGrid = true) => {
        if(cleanGrid) grid.innerHTML = '';
        emptyState.classList.add('hidden');
        grid.classList.remove('hidden');
        for(let i=0; i<count; i++) {
          const div = document.createElement('div');
          div.className = "flex flex-col bg-white rounded-3xl border border-slate-100 p-6 pb-8 shadow-sm h-full skeleton-shimmer opacity-50";
          div.style.minHeight = "360px";
          grid.appendChild(div);
        }
      };

      const toTitleCase = (str) => {
        if (!str) return '';
        const minors = ['y', 'de', 'del', 'el', 'la', 'los', 'las', 'en'];
        return str.toLowerCase().split(' ').map((w, i) => i > 0 && minors.includes(w) ? w : w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      };

      const slugify = (text) => {
        if (!text) return '';
        return text.toString().toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-').replace(/[^\w\-]+/g, '').replace(/\-\-+/g, '-');
      };

      // Extracción API
      const fetchEspecialidades = async () => {
        try {
          const res = await fetch('https://administrador.especialidadesmedicassur.com.mx/api/especialidad/get-all');
          const data = await res.json();
          let clean = (Array.isArray(data.data || data) ? (data.data || data) : []).filter(e => e.estatus === 1);
          clean = clean.map(esp => ({ ...esp, nombre: toTitleCase(esp.nombre) })).sort((a,b) => a.nombre.localeCompare(b.nombre, 'es'));
          
          clean.forEach(esp => {
            const opt = document.createElement('option');
            opt.value = esp.id; opt.textContent = esp.nombre;
            specialtySelect.appendChild(opt);
          });

          const keys = ['ginecología', 'pediatría', 'traumatología'];
          const suggested = clean.filter(esp => keys.some(k => esp.nombre.toLowerCase().includes(k))).slice(0, 3);
          
          quickFiltersContainer.innerHTML = '';
          suggested.forEach(esp => {
            const btn = document.createElement('button');
            btn.className = "px-4 py-2 rounded-xl text-sm font-bold bg-white border border-brand-cyan/20 text-brand-cyan hover:bg-brand-cyan hover:border-brand-cyan hover:text-white transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 whitespace-nowrap cursor-pointer";
            btn.textContent = esp.nombre;
            btn.onclick = () => { specialtySelect.value = esp.id; fetchDoctors(); };
            quickFiltersContainer.appendChild(btn);
          });
        } catch (error) {
          console.error("Error loaded especialidades", error);
        }
      };

      // Renderización E-E-A-T Cards
      const renderCards = (results, isLoadMore = false) => {
        if (!isLoadMore) grid.innerHTML = '';
        else grid.querySelectorAll('.skeleton-shimmer').forEach(sk => sk.remove());

        if (!isLoadMore && (!results || !results.length)) {
          grid.classList.add('hidden');
          emptyState.classList.remove('hidden');
          countEl.textContent = "0 ESPECIALISTAS ENCONTRADOS";
          return;
        }

        grid.classList.remove('hidden');
        emptyState.classList.add('hidden');
        if (!isLoadMore) countEl.innerHTML = `<i class="ph ph-check-circle mr-1"></i> Resultados encontrados para tu salud`;

        const batchClass = `batch-${Date.now()}`;

        results.forEach(doc => {
          const card = document.createElement('div');
          // Important: We omit translateY initial class to use GSAP proper injection
          card.className = `doctor-card ${batchClass} flex flex-col bg-white rounded-[2rem] border border-slate-100 p-6 pb-6 shadow-sm hover:shadow-2xl transition-shadow duration-500 group relative font-jakarta h-full`;
          const profileImg = doc.foto ? doc.foto : svgFallback;
          const docName = toTitleCase(doc.nombre);
          
          card.innerHTML = `
            <div class="flex flex-col items-center mb-5">
              <div class="w-28 h-28 mb-4 relative z-10">
                <div class="absolute inset-0 rounded-full border-[3px] border-brand-cyan/30 group-hover:border-brand-cyan transition-colors duration-500 scale-[1.05] group-hover:scale-[1.08] shadow-sm"></div>
                <div class="w-full h-full rounded-full overflow-hidden border-2 border-white bg-slate-50 relative z-20">
                  <img src="${profileImg}" alt="${docName}" loading="lazy" onerror="this.src='${svgFallback}'" class="w-full h-full object-cover" />
                </div>
              </div>
              <h3 class="text-[1.2rem] xl:text-[1.3rem] font-extrabold text-brand-blue tracking-tight leading-tight mb-2 text-center line-clamp-2">${docName}</h3>
              <p class="text-brand-cyan font-bold text-[0.7rem] xl:text-xs uppercase tracking-widest text-center line-clamp-1 mb-4">${doc.especialidad || 'Especialista Médico'}</p>
              
              <div class="inline-flex items-center justify-center px-4 py-1.5 bg-slate-50 rounded-full text-slate-500 text-xs font-bold border border-slate-100">
                <i class="ph ph-file-text text-brand-cyan mr-1.5 text-sm"></i> 
                Céd: ${doc.cedula || 'En Proceso'}
              </div>
            </div>

            <div class="mt-auto space-y-3 pt-5 border-t border-slate-100/80 relative z-10 w-full">
              <a href="/contacto" class="block w-full text-center bg-brand-cyan text-white py-3.5 rounded-full font-bold hover:bg-cyan-500 hover:shadow-lg hover:shadow-brand-cyan/30 active:scale-95 transition-all text-[0.95rem]">
                Agendar Cita
              </a>
              <a href="/directorio/${slugify(doc.nombre)}" class="flex w-full items-center justify-center text-sm font-bold text-slate-400 hover:text-brand-blue transition-colors py-2 group/link">
                Ver Perfil Completo 
                <i class="ph ph-arrow-right ml-1.5 transform group-hover/link:translate-x-1 group-hover/link:text-brand-cyan transition-all"></i>
              </a>
            </div>
          `;
          grid.appendChild(card);
        });

        // GSAP ScrollTrigger Fade-In + Slide-Up Recreativo
        if (typeof window.gsap !== 'undefined') {
          window.gsap.fromTo("." + batchClass, 
            { opacity: 0, y: 40 },
            { 
              opacity: 1, 
              y: 0, 
              duration: 0.8, 
              stagger: 0.1, 
              ease: "power2.out", 
              clearProps: "all",
              scrollTrigger: {
                trigger: "." + batchClass,
                start: "top 90%"
              }
            }
          );
        }
      };

      const fetchDoctors = async (isLoadMore = false) => {
        const nombre = searchInput.value.trim();
        const especialidadId = specialtySelect.value;
        if (!isLoadMore) {
          currentPage = 1;
          renderSkeletons(12, true);
          loadMoreContainer.classList.add('hidden');
        } else {
          loadMoreBtn.classList.add('opacity-50', 'pointer-events-none');
        }

        try {
          const urlParams = new URLSearchParams();
          if (nombre) urlParams.append('nombre', nombre);
          if (especialidadId) urlParams.append('especialidad_id', especialidadId);
          urlParams.append('per_page', '12'); urlParams.append('page', currentPage.toString());
          
          const ep = 'https://administrador.especialidadesmedicassur.com.mx/api/directorio-medico/search?' + urlParams.toString();
          const res = await fetch(ep);
          const data = await res.json();
          let results = []; let lastPage = 1;
          
          if (Array.isArray(data)) { results = data; }
          else if (data.data && Array.isArray(data.data)) { results = data.data; lastPage = data.last_page || 1; }
          else if (data.data?.data && Array.isArray(data.data.data)) { results = data.data.data; lastPage = data.data.last_page || 1; }

          renderCards(results, isLoadMore);
          
          loadMoreBtn.classList.remove('opacity-50', 'pointer-events-none');
          if (currentPage < lastPage) loadMoreContainer.classList.remove('hidden');
          else loadMoreContainer.classList.add('hidden');
        } catch (error) {
          if (!isLoadMore) { grid.innerHTML = ''; emptyState.classList.remove('hidden'); countEl.textContent = "Error de conexión temporal."; }
        }
      };

      // Init Layer
      renderSkeletons(8);
      await fetchEspecialidades();
      const uP = new URLSearchParams(window.location.search);
      const especialidadParam = uP.get('especialidad');
      if (especialidadParam) {
        // Normaliza el param recibido (slug) para compararlo contra los nombres del select
        const normalizeSlug = (str) => str.toString().toLowerCase().trim()
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
          .replace(/\s+/g, '-').replace(/[^\w\-]+/g, '').replace(/\-\-+/g, '-');
        const options = Array.from(specialtySelect.options);
        const match = options.find(opt => normalizeSlug(opt.textContent) === normalizeSlug(especialidadParam));
        if (match) specialtySelect.value = match.value;
      }
      fetchDoctors();

      searchBtn.addEventListener('click', () => fetchDoctors());
      specialtySelect.addEventListener('change', () => fetchDoctors());
      searchInput.addEventListener('input', () => { clearTimeout(debounceTimer); debounceTimer = setTimeout(() => fetchDoctors(), 600); });
      searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') { clearTimeout(debounceTimer); fetchDoctors(); } });
      loadMoreBtn.addEventListener('click', () => { currentPage++; fetchDoctors(true); });

      // Animaciones GSAP Estáticas para Elementos Core
      if (typeof window.gsap !== 'undefined') {
        // Deshabilitadas temporalmente para prevenir fallos de ScrollTrigger por altura dinámica
        /* window.gsap.from(".action-grid a", {
          scrollTrigger: { trigger: ".action-grid", start: "top 85%" },
          y: 30, opacity: 0, duration: 0.8, stagger: 0.15, ease: "back.out(1.2)"
        });
        window.gsap.from(".faq-header, .faq-item", {
          scrollTrigger: { trigger: ".faq-header", start: "top 85%" },
          y: 20, opacity: 0, duration: 0.6, stagger: 0.1, ease: "power2.out"
        }); */
        
        // Bounce Animation "Mostrar Más"
        window.gsap.to("#load-more-btn", {
          y: -6,
          repeat: -1,
          yoyo: true,
          duration: 1.2,
          ease: "power1.inOut",
          scrollTrigger: { trigger: "#load-more-container", toggleActions: "play pause resume pause" }
        });
      }
    });
  </script>
</Layout>
