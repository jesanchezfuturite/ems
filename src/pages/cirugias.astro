---
import Layout from "../layouts/Layout.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalBusiness",
      "name": "Centro de Especialidades Médicas en Monterrey",
      "image": "https://christus.mx/sur/images/cirugia_gen.webp",
      "@id": "https://christus.mx/sur",
      "url": "https://christus.mx/sur",
      "telephone": "+528180000000",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Av. Principal 123",
        "addressLocality": "Monterrey",
        "addressRegion": "NL",
        "postalCode": "64000",
        "addressCountry": "MX"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuándo debo acudir a un especialista médico?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Debes acudir a un especialista cuando presentas síntomas persistentes, dolor continuo o cuando necesitas un diagnóstico más preciso en áreas como cardiología, neurología o gastroenterología."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué hace un médico especialista?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un especialista es un médico con formación avanzada en un área específica, capacitado para diagnosticar y tratar enfermedades complejas de forma más precisa."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo elegir la especialidad médica correcta?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Depende de tus síntomas. Por ejemplo, problemas digestivos corresponden a gastroenterología, síntomas respiratorios a neumología y afecciones de la piel a dermatología."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué estudios debo llevar a mi primera consulta?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Se recomienda llevar estudios previos, análisis clínicos, radiografías o cualquier historial médico que ayude al especialista a evaluar tu caso de forma más completa."
          }
        },
        {
          "@type": "Question",
          "name": "¿Necesito referencia médica para consultar a un especialista?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No es necesario. Puedes agendar directamente con el especialista indicado según tus síntomas o necesidades."
          }
        }
      ]
    }
  ]
};
---

<Layout
  title="Centro de Especialidades Médicas en Monterrey | Excelencia Clínica"
  description="Especialistas certificados, diagnóstico oportuno y tratamientos personalizados para tu bienestar."
>
  <!-- SEO: Schema JSON-LD agregado al head via fragment o set:html -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. Hero Section -->
  <section class="relative bg-slate-900 pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden text-white">
    <!-- Overlay image -->
    <div class="absolute inset-0 z-0">
      <img src="/images/imggen_1.webp" alt="Centro de Especialidades Médicas" class="w-full h-full object-cover opacity-20 mix-blend-overlay" />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/90 to-slate-900/40"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col xl:flex-row items-center gap-12 lg:gap-16">
      <div class="w-full xl:w-1/2 flex flex-col items-start z-10">
        <span class="inline-block bg-sky-600/20 text-sky-400 px-4 py-1.5 rounded-full text-sm font-semibold tracking-wide border border-sky-500/30 mb-6">
          Atención Médica de Excelencia
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-5xl font-extrabold text-white mb-6 leading-[1.15]">
          Centro de Especialidades Médicas en Monterrey
        </h1>
        <p class="text-lg md:text-xl text-slate-300 mb-10 max-w-xl leading-relaxed">
          Especialistas certificados, diagnóstico oportuno y tratamientos personalizados para tu bienestar.
        </p>
        <a href="/contacto" class="inline-flex items-center justify-center px-8 py-4 bg-sky-600 text-white text-lg font-bold rounded-2xl hover:bg-sky-500 transition-all shadow-xl shadow-sky-600/30 transform hover:-translate-y-1">
          Agendar Consulta <i class="ph ph-calendar-plus text-2xl ml-2"></i>
        </a>
      </div>
      
      <div class="w-full xl:w-1/2 relative hidden md:block">
        <div class="relative w-full aspect-[4/3] rounded-[2rem] overflow-hidden shadow-2xl shadow-sky-900/20 border border-slate-700/50">
           <!-- Nueva imagen de título (imggen_1.webp) - Aspecto ajustado evita que se corten personas en el centro -->
           <img src="/images/imggen_1.webp" alt="Héroe Especialidades Médicas" class="w-full h-full object-cover object-center scale-100 hover:scale-105 transition-transform duration-700" />
           <!-- Gradient over image for readability if needed -->
           <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent pointer-events-none"></div>
        </div>
        <!-- Decoration element -->
        <div class="absolute -bottom-8 lg:bottom-4 -left-4 lg:-left-12 bg-white rounded-2xl p-6 shadow-2xl z-20">
          <div class="flex items-center gap-4">
             <div class="w-12 h-12 bg-sky-100 rounded-full flex items-center justify-center text-sky-600">
               <i class="ph ph-stethoscope text-2xl"></i>
             </div>
             <div>
               <p class="text-slate-900 font-bold text-lg leading-tight">Especialistas</p>
               <p class="text-slate-500 text-sm">Certificados</p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Sección "Nuestras Especialidades" (Bento Grid Interactivo) -->
  <section class="py-24 bg-slate-50 relative specialties-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6">
          Nuestras Especialidades
        </h2>
        <p class="text-lg text-slate-600">
          Ofrecemos un espectro completo de especialidades, integrando conocimiento clínico para dar respuesta a tus necesidades de salud con la más alta precisión.
        </p>
      </div>

      <!-- Importante: Marcado interno con ul y li para SEO -->
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 list-none p-0 m-0">
        <!-- Card 1 -->
        <li class="specialty-card group relative bg-white p-8 rounded-[2rem] border border-slate-100 shadow-lg hover:shadow-2xl hover:border-sky-200 transition-all duration-500 flex flex-col items-start translate-y-0 hover:-translate-y-2">
           <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-sky-600 mb-6 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300">
             <i class="ph ph-heartbeat text-3xl"></i>
           </div>
           <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-sky-600 transition-colors">Cardiología</h3>
           <p class="text-slate-800 font-medium text-sm leading-relaxed mb-2">
             Diagnóstico y tratamiento de enfermedades del corazón y sistema cardiovascular.
           </p>
           <p class="text-slate-500 text-xs leading-relaxed mb-6">
             La Cardiología es la especialidad médica enfocada en la prevención, diagnóstico y tratamiento de enfermedades del corazón y sistema cardiovascular.
           </p>
           <a href="/directorio" class="mt-auto text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
             Directorio <i class="ph ph-arrow-right ml-1"></i>
           </a>
        </li>
        <!-- Card 2 -->
        <li class="specialty-card group relative bg-white p-8 rounded-[2rem] border border-slate-100 shadow-lg hover:shadow-2xl hover:border-sky-200 transition-all duration-500 flex flex-col items-start translate-y-0 hover:-translate-y-2">
           <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-sky-600 mb-6 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300">
             <i class="ph ph-hand-soap text-3xl"></i>
           </div>
           <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-sky-600 transition-colors">Dermatología</h3>
           <p class="text-slate-800 font-medium text-sm leading-relaxed mb-2">
             Atención médica especializada en la salud de la piel, cabello y uñas.
           </p>
           <p class="text-slate-500 text-xs leading-relaxed mb-6">
             La Dermatología es la especialidad médica dedicada al cuidado, diagnóstico y tratamiento de enfermedades de la piel, cabello y uñas.
           </p>
           <a href="/directorio" class="mt-auto text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
             Directorio <i class="ph ph-arrow-right ml-1"></i>
           </a>
        </li>
        <!-- Card 3 -->
        <li class="specialty-card group relative bg-white p-8 rounded-[2rem] border border-slate-100 shadow-lg hover:shadow-2xl hover:border-sky-200 transition-all duration-500 flex flex-col items-start translate-y-0 hover:-translate-y-2">
           <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-sky-600 mb-6 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300">
             <i class="ph ph-brain text-3xl"></i>
           </div>
           <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-sky-600 transition-colors">Neurología</h3>
           <p class="text-slate-800 font-medium text-sm leading-relaxed mb-2">
             Diagnóstico y manejo de enfermedades del sistema nervioso central y periférico.
           </p>
           <p class="text-slate-500 text-xs leading-relaxed mb-6">
             La Neurología es la especialidad médica encargada del diagnóstico y tratamiento de trastornos del sistema nervioso central y periférico.
           </p>
           <a href="/directorio" class="mt-auto text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
             Directorio <i class="ph ph-arrow-right ml-1"></i>
           </a>
        </li>
        <!-- Card 4 -->
        <li class="specialty-card group relative bg-white p-8 rounded-[2rem] border border-slate-100 shadow-lg hover:shadow-2xl hover:border-sky-200 transition-all duration-500 flex flex-col items-start translate-y-0 hover:-translate-y-2">
           <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-sky-600 mb-6 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300">
             <i class="ph ph-lungs text-3xl"></i>
           </div>
           <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-sky-600 transition-colors">Neumología</h3>
           <p class="text-slate-800 font-medium text-sm leading-relaxed mb-2">
             Tratamiento de enfermedades respiratorias como asma, EPOC e infecciones pulmonares.
           </p>
           <p class="text-slate-500 text-xs leading-relaxed mb-6">
             La Neumología es la especialidad médica enfocada en la prevención, diagnóstico y tratamiento de enfermedades del sistema respiratorio.
           </p>
           <a href="/directorio" class="mt-auto text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
             Directorio <i class="ph ph-arrow-right ml-1"></i>
           </a>
        </li>
        <!-- Card 5 -->
        <li class="specialty-card group relative bg-white p-8 rounded-[2rem] border border-slate-100 shadow-lg hover:shadow-2xl hover:border-sky-200 transition-all duration-500 flex flex-col items-start translate-y-0 hover:-translate-y-2">
           <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-sky-600 mb-6 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300">
             <i class="ph ph-head-circuit text-3xl"></i>
           </div>
           <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-sky-600 transition-colors">Psiquiatría</h3>
           <p class="text-slate-800 font-medium text-sm leading-relaxed mb-2">
             Evaluación y tratamiento de trastornos mentales y emocionales.
           </p>
           <p class="text-slate-500 text-xs leading-relaxed mb-6">
             La Psiquiatría es la especialidad médica dedicada al diagnóstico, tratamiento y prevención de trastornos mentales y emocionales.
           </p>
           <a href="/directorio" class="mt-auto text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
             Directorio <i class="ph ph-arrow-right ml-1"></i>
           </a>
        </li>
        <!-- Card 6 -->
        <li class="specialty-card group relative bg-white p-8 rounded-[2rem] border border-slate-100 shadow-lg hover:shadow-2xl hover:border-sky-200 transition-all duration-500 flex flex-col items-start translate-y-0 hover:-translate-y-2">
           <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-sky-600 mb-6 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300">
             <i class="ph ph-drop text-3xl"></i>
           </div>
           <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-sky-600 transition-colors">Hepatología</h3>
           <p class="text-slate-800 font-medium text-sm leading-relaxed mb-2">
             Especialidad enfocada en el diagnóstico y tratamiento de enfermedades del hígado.
           </p>
           <p class="text-slate-500 text-xs leading-relaxed mb-6">
             La Hepatología es la especialidad médica centrada en el estudio, diagnóstico y tratamiento de enfermedades del hígado.
           </p>
           <a href="/directorio" class="mt-auto text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
             Directorio <i class="ph ph-arrow-right ml-1"></i>
           </a>
        </li>
        <!-- Card 7 -->
        <li class="specialty-card group relative bg-white p-8 rounded-[2rem] border border-slate-100 shadow-lg hover:shadow-2xl hover:border-sky-200 transition-all duration-500 flex flex-col items-start translate-y-0 hover:-translate-y-2">
           <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-sky-600 mb-6 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300">
             <i class="ph ph-activity text-3xl"></i>
           </div>
           <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-sky-600 transition-colors">Hematología</h3>
           <p class="text-slate-800 font-medium text-sm leading-relaxed mb-2">
             Atención de enfermedades de la sangre y trastornos hematológicos.
           </p>
           <p class="text-slate-500 text-xs leading-relaxed mb-6">
             La Hematología es la especialidad médica enfocada en el diagnóstico y tratamiento de enfermedades de la sangre.
           </p>
           <a href="/directorio" class="mt-auto text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
             Directorio <i class="ph ph-arrow-right ml-1"></i>
           </a>
        </li>
        <!-- Card 8 -->
        <li class="specialty-card group relative bg-white p-8 rounded-[2rem] border border-slate-100 shadow-lg hover:shadow-2xl hover:border-sky-200 transition-all duration-500 flex flex-col items-start translate-y-0 hover:-translate-y-2">
           <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-sky-600 mb-6 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300">
             <i class="ph ph-stomach text-3xl"></i>
           </div>
           <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-sky-600 transition-colors">Gastroenterología</h3>
           <p class="text-slate-800 font-medium text-sm leading-relaxed mb-2">
             Diagnóstico y tratamiento de enfermedades del sistema digestivo.
           </p>
           <p class="text-slate-500 text-xs leading-relaxed mb-6">
             La Gastroenterología es la especialidad médica dedicada al diagnóstico y tratamiento de enfermedades del sistema digestivo.
           </p>
           <a href="/directorio" class="mt-auto text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
             Directorio <i class="ph ph-arrow-right ml-1"></i>
           </a>
        </li>
      </ul>
    </div>
  </section>

  <!-- 3. Bloques de Autoridad y Confianza -->
  <section class="py-24 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="bg-slate-900 rounded-[3rem] p-10 lg:p-16 relative overflow-hidden shadow-2xl flex flex-col lg:flex-row items-center justify-between gap-12">
        <!-- Glow background -->
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-sky-600/30 blur-[100px] rounded-full"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-slate-700/50 blur-[100px] rounded-full"></div>

        <div class="lg:w-1/2 relative z-10 text-center lg:text-left">
          <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
            ¿Por qué confiar en nuestros especialistas?
          </h2>
          <p class="text-lg text-slate-300 leading-relaxed max-w-xl mx-auto lg:mx-0">
            Nuestros médicos están certificados por los principales consejos nacionales e internacionales. Trabajamos de forma multidisciplinaria para ofrecer diagnósticos precisos en casos complejos.
          </p>
        </div>

        <div class="lg:w-1/2 relative z-10 flex justify-center lg:justify-end w-full">
           <div class="grid grid-cols-2 gap-4 w-full max-w-md">
             <div class="bg-slate-800/80 backdrop-blur-sm border border-slate-700 p-6 rounded-2xl flex flex-col items-center text-center group">
                <i class="ph ph-certificate text-4xl text-sky-400 mb-3 group-hover:scale-110 transition-transform"></i>
                <h4 class="text-white font-bold text-sm">Consejo Médico Nacional</h4>
             </div>
             <div class="bg-slate-800/80 backdrop-blur-sm border border-slate-700 p-6 rounded-2xl flex flex-col items-center text-center group">
                <i class="ph ph-globe-hemisphere-west text-4xl text-sky-400 mb-3 group-hover:scale-110 transition-transform"></i>
                <h4 class="text-white font-bold text-sm">Práctica Internacional</h4>
             </div>
             <div class="bg-slate-800/80 backdrop-blur-sm border border-slate-700 p-6 rounded-2xl flex flex-col items-center text-center group">
                <i class="ph ph-users-three text-4xl text-sky-400 mb-3 group-hover:scale-110 transition-transform"></i>
                <h4 class="text-white font-bold text-sm">Enfoque Multidisciplinario</h4>
             </div>
             <div class="bg-slate-800/80 backdrop-blur-sm border border-slate-700 p-6 rounded-2xl flex flex-col items-center text-center group">
                <i class="ph ph-star text-4xl text-sky-400 mb-3 group-hover:scale-110 transition-transform"></i>
                <h4 class="text-white font-bold text-sm">Excelencia Clínica</h4>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Proceso del Paciente -->
  <section class="py-24 bg-slate-50 relative process-section border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20 max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6">
          El camino hacia tu bienestar
        </h2>
        <p class="text-lg text-slate-600">
          Un proceso claro y transparente diseñado para acompañarte en cada paso de tu recuperación y mejora de tu salud.
        </p>
      </div>

      <div class="relative max-w-5xl mx-auto">
        <!-- Línea conectora -->
        <div class="hidden md:block absolute top-[2.5rem] left-[12%] right-[12%] h-[2px] bg-slate-200"></div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-6 relative z-10">
          
          <div class="process-step flex flex-col items-center text-center">
             <div class="w-20 h-20 bg-white rounded-full shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 flex items-center justify-center text-sky-600 mb-6 group hover:scale-110 transition-transform relative z-10">
               <span class="text-2xl font-black">1</span>
             </div>
             <h4 class="text-lg font-bold text-slate-900 mb-2">Consulta diagnóstica con especialista</h4>
             <p class="text-sm text-slate-500 leading-relaxed px-2">Evaluación profunda por parte de un médico experto para identificar tus síntomas y necesidades.</p>
          </div>

          <div class="process-step flex flex-col items-center text-center">
             <div class="w-20 h-20 bg-sky-600 rounded-full shadow-[0_10px_40px_-10px_rgba(2,132,199,0.4)] border-4 border-slate-50 flex items-center justify-center text-white mb-6 group hover:scale-110 transition-transform relative z-10">
               <span class="text-2xl font-black">2</span>
             </div>
             <h4 class="text-lg font-bold text-slate-900 mb-2">Estudios de precisión</h4>
             <p class="text-sm text-slate-500 leading-relaxed px-2">Laboratorio e imagenología de avanzada para corroborar diagnósticos con certeza absoluta.</p>
          </div>

          <div class="process-step flex flex-col items-center text-center">
             <div class="w-20 h-20 bg-white rounded-full shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 flex items-center justify-center text-sky-600 mb-6 group hover:scale-110 transition-transform relative z-10">
               <span class="text-2xl font-black">3</span>
             </div>
             <h4 class="text-lg font-bold text-slate-900 mb-2">Plan de tratamiento personalizado</h4>
             <p class="text-sm text-slate-500 leading-relaxed px-2">Desarrollo de un protocolo clínico y terapéutico hecho a la medida de tu condición específica.</p>
          </div>

          <div class="process-step flex flex-col items-center text-center">
             <div class="w-20 h-20 bg-white rounded-full shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 flex items-center justify-center text-sky-600 mb-6 group hover:scale-110 transition-transform relative z-10">
               <span class="text-2xl font-black">4</span>
             </div>
             <h4 class="text-lg font-bold text-slate-900 mb-2">Seguimiento continuo</h4>
             <p class="text-sm text-slate-500 leading-relaxed px-2">Monitoreo constante de tu evolución para asegurar la completa restitución de tu salud.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- 5. Sección FAQ -->
  <section class="py-24 bg-white relative">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
          Preguntas Frecuentes
        </h2>
        <p class="text-lg text-slate-600">
          Resolvemos tus dudas sobre nuestra atención de especialidad médica.
        </p>
      </div>

      <div class="space-y-4">
        <details class="group bg-slate-50 rounded-2xl p-6 open:bg-sky-50 open:ring-2 open:ring-sky-500/20 transition-all duration-300">
          <summary class="flex justify-between items-center font-bold cursor-pointer text-slate-900 text-lg">
            ¿Cuándo debo acudir a un especialista médico?
            <span class="transition group-open:rotate-180">
              <i class="ph ph-caret-down text-xl text-sky-600"></i>
            </span>
          </summary>
          <p class="text-slate-600 mt-4 leading-relaxed">
            Debes acudir a un especialista cuando presentas síntomas persistentes, dolor continuo o cuando necesitas un diagnóstico más preciso en áreas como cardiología, neurología o gastroenterología.
          </p>
        </details>
        
        <details class="group bg-slate-50 rounded-2xl p-6 open:bg-sky-50 open:ring-2 open:ring-sky-500/20 transition-all duration-300">
          <summary class="flex justify-between items-center font-bold cursor-pointer text-slate-900 text-lg">
            ¿Qué hace un médico especialista?
            <span class="transition group-open:rotate-180">
              <i class="ph ph-caret-down text-xl text-sky-600"></i>
            </span>
          </summary>
          <p class="text-slate-600 mt-4 leading-relaxed">
            Un especialista es un médico con formación avanzada en un área específica, capacitado para diagnosticar y tratar enfermedades complejas de forma más precisa.
          </p>
        </details>

        <details class="group bg-slate-50 rounded-2xl p-6 open:bg-sky-50 open:ring-2 open:ring-sky-500/20 transition-all duration-300">
          <summary class="flex justify-between items-center font-bold cursor-pointer text-slate-900 text-lg">
            ¿Cómo elegir la especialidad médica correcta?
            <span class="transition group-open:rotate-180">
              <i class="ph ph-caret-down text-xl text-sky-600"></i>
            </span>
          </summary>
          <p class="text-slate-600 mt-4 leading-relaxed">
            Depende de tus síntomas. Por ejemplo, problemas digestivos corresponden a gastroenterología, síntomas respiratorios a neumología y afecciones de la piel a dermatología.
          </p>
        </details>

        <details class="group bg-slate-50 rounded-2xl p-6 open:bg-sky-50 open:ring-2 open:ring-sky-500/20 transition-all duration-300">
          <summary class="flex justify-between items-center font-bold cursor-pointer text-slate-900 text-lg">
            ¿Qué estudios debo llevar a mi primera consulta?
            <span class="transition group-open:rotate-180">
              <i class="ph ph-caret-down text-xl text-sky-600"></i>
            </span>
          </summary>
          <p class="text-slate-600 mt-4 leading-relaxed">
            Se recomienda llevar estudios previos, análisis clínicos, radiografías o cualquier historial médico que ayude al especialista a evaluar tu caso de forma más completa.
          </p>
        </details>

        <details class="group bg-slate-50 rounded-2xl p-6 open:bg-sky-50 open:ring-2 open:ring-sky-500/20 transition-all duration-300">
          <summary class="flex justify-between items-center font-bold cursor-pointer text-slate-900 text-lg">
            ¿Necesito referencia médica para consultar a un especialista?
            <span class="transition group-open:rotate-180">
              <i class="ph ph-caret-down text-xl text-sky-600"></i>
            </span>
          </summary>
          <p class="text-slate-600 mt-4 leading-relaxed">
            No es necesario. Puedes agendar directamente con el especialista indicado según tus síntomas o necesidades.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Lógica de Animaciones GSAP -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      // Small timeout to ensure custom elements/images loads visually stabilize
      setTimeout(() => {
          if (typeof window.gsap !== "undefined" && window.ScrollTrigger) {
            
            // Animación de las cards de especialidad (Stagger)
            window.gsap.from(".specialty-card", {
              scrollTrigger: {
                trigger: ".specialties-section",
                start: "top 80%",
              },
              y: 40,
              opacity: 0,
              duration: 0.8,
              stagger: 0.15,
              ease: "power2.out",
              clearProps: "all",
            });

            // Animación de la línea de proceso
            window.gsap.from(".process-step", {
              scrollTrigger: {
                trigger: ".process-section",
                start: "top 75%",
              },
              scale: 0.8,
              opacity: 0,
              y: 30,
              duration: 0.6,
              stagger: 0.2,
              ease: "back.out(1.5)",
              clearProps: "all",
            });
          }
      }, 100);
    });
  </script>
</Layout>
