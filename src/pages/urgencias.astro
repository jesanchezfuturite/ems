---
import Layout from '../layouts/Layout.astro';

// 1. SEO & Metadatos Críticos
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EmergencyService",
  "name": "Urgencias 24 Horas Centro de Especialidades Médicas",
  "telephone": "+528181555000",
  "email": "urgencias@especialidadesmedicas.mx",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Carretera Nacional Km 265",
    "addressLocality": "Monterrey",
    "addressRegion": "N.L.",
    "postalCode": "64988",
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 25.5670,
    "longitude": -100.2450
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"
    ],
    "opens": "00:00",
    "closes": "23:59"
  }
};
---

<Layout 
  title="Urgencias 24 Horas en Monterrey Sur | Christus Muguerza"
  description="Atención médica inmediata las 24 horas. Especialistas en trauma, cardiología y urgencias pediátricas. Ubicación y contacto directo aquí."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 2. Hero de Acción Inmediata (Red Alert) -->
  <section class="bg-white pt-24 pb-16 border-b border-rose-100 relative overflow-hidden">
    <!-- Círculos de alerta decoración -->
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-red-50 rounded-full blur-3xl opacity-60 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-rose-50 rounded-full blur-3xl opacity-60 pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center mt-8">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-red-50 rounded-full mb-6">
        <i class="ph ph-ambulance text-4xl text-[#e11d48]"></i>
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-slate-900 mb-6 tracking-tight leading-none uppercase">
        Urgencias Médicas <span class="text-[#e11d48]">24/7</span>
      </h1>
      <p class="text-xl md:text-2xl text-slate-600 mb-10 max-w-2xl mx-auto font-medium">
        Atención inmediata sin previa cita. Médicos especialistas siempre presentes.
      </p>
      
      <!-- Contenedor de Acciones (Mobile-First) -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:8181555000" class="btn-emergency w-full sm:w-auto px-8 py-5 bg-[#e11d48] text-white text-lg md:text-xl font-bold rounded-2xl md:rounded-full hover:bg-rose-700 transition-colors shadow-lg shadow-rose-500/40 flex items-center justify-center border-2 border-[#e11d48]">
          <i class="ph ph-phone-call text-2xl mr-3 animate-pulse"></i>
          LLAMAR A URGENCIAS: (81) 8155 5000
        </a>
        <a href="https://maps.app.goo.gl/VDCtEy4roU6DTcko8" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-8 py-5 bg-white text-slate-700 text-lg md:text-xl font-bold rounded-2xl md:rounded-full hover:bg-slate-50 transition-colors shadow-sm flex items-center justify-center border border-slate-200">
          <i class="ph ph-map-pin text-2xl mr-3 text-[#e11d48]"></i>
          Cómo llegar (Google Maps)
        </a>
      </div>
    </div>
  </section>

  <!-- 3. Sección "Triage": ¿Cuándo acudir a Urgencias? -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-blue mb-4">¿Cuándo acudir a Urgencias?</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Identifica tu nivel de urgencia para saber cómo actuar. Nuestro sistema de Triage garantiza atención prioritaria a pacientes críticos.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Nivel Rojo -->
        <div class="urgency-card bg-white rounded-[32px] p-8 border-t-8 border-[#e11d48] shadow-lg shadow-red-900/5 relative overflow-hidden group">
          <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-20 transition-opacity">
            <i class="ph-fill ph-heartbeat text-8xl text-[#e11d48]"></i>
          </div>
          <div class="w-14 h-14 bg-red-50 rounded-2xl flex items-center justify-center mb-6">
            <span class="text-2xl font-black text-[#e11d48]">1</span>
          </div>
          <h3 class="text-2xl font-bold text-slate-800 mb-2">Nivel Rojo</h3>
          <p class="text-[#e11d48] font-bold text-sm uppercase tracking-wide mb-6">Atención Inmediata</p>
          <ul class="space-y-4 text-slate-600">
             <li class="flex items-start"><i class="ph ph-warning-circle text-[#e11d48] mt-1 mr-3 text-lg"></i> Dolor de pecho severo</li>
             <li class="flex items-start"><i class="ph ph-warning-circle text-[#e11d48] mt-1 mr-3 text-lg"></i> Dificultad para respirar</li>
             <li class="flex items-start"><i class="ph ph-warning-circle text-[#e11d48] mt-1 mr-3 text-lg"></i> Pérdida de conciencia</li>
             <li class="flex items-start"><i class="ph ph-warning-circle text-[#e11d48] mt-1 mr-3 text-lg"></i> Sangrado abundante que no se detiene</li>
          </ul>
        </div>

        <!-- Nivel Amarillo -->
        <div class="urgency-card bg-white rounded-[32px] p-8 border-t-8 border-amber-400 shadow-lg shadow-amber-900/5 relative overflow-hidden group">
          <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-20 transition-opacity">
            <i class="ph-fill ph-bandaids text-8xl text-amber-400"></i>
          </div>
          <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center mb-6">
            <span class="text-2xl font-black text-amber-500">2</span>
          </div>
          <h3 class="text-2xl font-bold text-slate-800 mb-2">Nivel Amarillo</h3>
          <p class="text-amber-500 font-bold text-sm uppercase tracking-wide mb-6">Atención Urgente</p>
          <ul class="space-y-4 text-slate-600">
             <li class="flex items-start"><i class="ph ph-warning-circle text-amber-500 mt-1 mr-3 text-lg"></i> Fracturas expuestas o dolorosas</li>
             <li class="flex items-start"><i class="ph ph-warning-circle text-amber-500 mt-1 mr-3 text-lg"></i> Quemaduras de consideración</li>
             <li class="flex items-start"><i class="ph ph-warning-circle text-amber-500 mt-1 mr-3 text-lg"></i> Dolor abdominal agudo e intenso</li>
             <li class="flex items-start"><i class="ph ph-warning-circle text-amber-500 mt-1 mr-3 text-lg"></i> Traumatismos o golpes fuertes en la cabeza</li>
          </ul>
        </div>

        <!-- Nivel Verde -->
        <div class="urgency-card bg-white rounded-[32px] p-8 border-t-8 border-emerald-500 shadow-lg shadow-emerald-900/5 relative overflow-hidden group">
          <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-20 transition-opacity">
            <i class="ph-fill ph-thermometer text-8xl text-emerald-500"></i>
          </div>
          <div class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center mb-6">
            <span class="text-2xl font-black text-emerald-600">3</span>
          </div>
          <h3 class="text-2xl font-bold text-slate-800 mb-2">Nivel Verde</h3>
          <p class="text-emerald-600 font-bold text-sm uppercase tracking-wide mb-6">Atención Médica (Menor Urgencia)</p>
          <ul class="space-y-4 text-slate-600">
             <li class="flex items-start"><i class="ph ph-check-circle text-emerald-500 mt-1 mr-3 text-lg"></i> Fiebre persistente sin signos de alarma</li>
             <li class="flex items-start"><i class="ph ph-check-circle text-emerald-500 mt-1 mr-3 text-lg"></i> Cortes superficiales o heridas menores</li>
             <li class="flex items-start"><i class="ph ph-check-circle text-emerald-500 mt-1 mr-3 text-lg"></i> Infecciones de garganta u oído</li>
             <li class="flex items-start"><i class="ph ph-check-circle text-emerald-500 mt-1 mr-3 text-lg"></i> Esguinces leves</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Infraestructura de Emergencia -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-brand-blue mb-4">Infraestructura de Nivel Internacional</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Preparados tecnológicamente y humanamente para cualquier eventualidad.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- Point 1 -->
        <div class="text-center p-6 border border-slate-100 rounded-[32px] hover:shadow-xl hover:border-blue-100 transition-all duration-300">
          <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="ph ph-activity text-5xl text-[#e11d48]"></i>
          </div>
          <h3 class="text-xl font-bold text-brand-blue mb-3">Unidad de Choque y Trauma</h3>
          <p class="text-slate-600 leading-relaxed">
            Equipamiento de asitencia vital avanzada y personal altamente calificado para recibir y estabilizar casos críticos y accidentes severos.
          </p>
        </div>
        <!-- Point 2 -->
        <div class="text-center p-6 border border-slate-100 rounded-[32px] hover:shadow-xl hover:border-blue-100 transition-all duration-300">
          <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="ph ph-heartbeat text-5xl text-[#e11d48]"></i>
          </div>
          <h3 class="text-xl font-bold text-brand-blue mb-3">Cardiólogos 24/7</h3>
          <p class="text-slate-600 leading-relaxed">
            Protocolo de <strong>Código Infarto</strong> activo y disponible todo el tiempo. Salvamos tejido cardíaco mediante intervención inmediata en sala de hemodinamia.
          </p>
        </div>
        <!-- Point 3 -->
        <div class="text-center p-6 border border-slate-100 rounded-[32px] hover:shadow-xl hover:border-blue-100 transition-all duration-300">
          <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="ph ph-baby text-5xl text-[#e11d48]"></i>
          </div>
          <h3 class="text-xl font-bold text-brand-blue mb-3">Urgencias Pediátricas</h3>
          <p class="text-slate-600 leading-relaxed">
             Tu familia en las mejores manos. Área física independiente, exclusiva y acondicionada para brindar un espacio seguro y menos estresante para los niños.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Mapa Interactivo -->
  <section class="pb-24 pt-8 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-blue mb-8">¿Cómo llegar?</h2>
      <div class="w-full h-[400px] mb-6 rounded-3xl overflow-hidden shadow-xl border border-slate-200">
        <iframe 
           src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d1799.2354648445735!2d-100.2587855!3d25.5892631!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8662c0aa5f4574d5%3A0x5403799d251348f0!2sCHRISTUS%20MUGUERZA%20Hospital%20Sur!5e0!3m2!1sen!2smx!4v1775668234622!5m2!1sen!2smx" 
           width="100%" 
           height="100%" 
           style="border:0;" 
           allowfullscreen="" 
           loading="lazy" 
           referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
      <p class="text-slate-600 font-medium text-lg">
        <i class="ph-fill ph-map-pin mr-2 text-[#e11d48]"></i> Carretera Nacional 6501, La Estanzuela, 64988 Monterrey, N.L.
      </p>
    </div>
  </section>

  <!-- 6. Lógica de Animación (GSAP) -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof window.gsap !== 'undefined') {
        const gsap = window.gsap;
        
        // Efecto Pulse para el botón de llamada
        gsap.to(".btn-emergency", {
          scale: 1.05,
          duration: 0.6,
          repeat: -1,
          yoyo: true,
          ease: "power1.inOut"
        });

        // Revelado suave de las secciones (Triage) con ScrollTrigger si es posible, o inmediato
        gsap.from(".urgency-card", {
          scrollTrigger: {
            trigger: ".urgency-card",
            start: "top 80%"
          },
          opacity: 0,
          y: 30,
          stagger: 0.2,
          duration: 0.8,
          ease: "power2.out"
        });
      }
    });
  </script>
</Layout>
