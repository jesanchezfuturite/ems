---
import Layout from '../../layouts/Layout.astro';

// 1. Fetching logic para generar las rutas estáticas basadas en la API
export async function getStaticPaths() {
  let articles: any[] = [];
  try {
    const res = await fetch('https://hospital.futurite.info/api/v1/public/blog-articles');
    const json = await res.json();
    if (json.Code === 200 && json.data) {
      articles = json.data;
    }
  } catch(error) {
    console.error("Error fetching getStaticPaths in blog", error);
  }

  return articles.map((article: any) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;

const stripHtml = (html: string) => {
  if (!html) return "";
  return html.replace(/<[^>]*>?/gm, '').substring(0, 160) + '...';
};

const title = article.title;
const description = stripHtml(article.content);
const image = article.cover_image;
const datePub = new Date(article.created_at);
const mainCat = article.tags && article.tags.length > 0 ? article.tags[0] : 'Salud General';

// 2. Schema Logic
const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": image,
  "author": {
    "@type": "Person",
    "name": "Especialistas CMS"
  },
  "publisher": {
    "@type": "MedicalOrganization",
    "name": "Centro de Especialidades Médicas",
    "logo": {
      "@type": "ImageObject",
      "url": "https://christus.mx/sur/images/logo.webp"
    }
  },
  "datePublished": datePub.toISOString()
};
---

<Layout 
  title={`${title} | Blog Médico`}
  description={description}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

  <article class="bg-white pb-24 border-b border-slate-100">
    
    <!-- Hero Header del Post -->
    <header class="relative w-full h-[60vh] min-h-[400px] flex items-end pb-16 overflow-hidden">
      <!-- Background Image -->
      <img 
        src={image} 
        alt={title} 
        class="absolute inset-0 w-full h-full object-cover z-0" 
      />
      <!-- Gradient Overlay para legibilidad text-white -->
      <div class="absolute inset-0 bg-gradient-to-t from-brand-blue flex-col opacity-90 to-transparent z-10 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/40 to-transparent z-10"></div>
      
      <div class="relative z-20 w-full max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center space-x-3 mb-6">
          <span class="bg-brand-cyan text-white px-4 py-1.5 rounded-full text-xs font-bold tracking-widest uppercase shadow-sm">
            {mainCat}
          </span>
          <span class="text-white/80 text-sm font-semibold flex items-center">
            <i class="ph ph-clock mr-1"></i> Lectura de 5 min
          </span>
        </div>
        
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight tracking-tight">
          {title}
        </h1>
        
        <div class="flex flex-col sm:flex-row sm:items-center text-white/90">
          <div class="flex items-center mb-4 sm:mb-0">
             <div class="w-12 h-12 rounded-full bg-slate-200 mr-4 flex items-center justify-center overflow-hidden border-2 border-white/20">
               <i class="ph ph-user text-2xl text-slate-500"></i>
             </div>
             <div>
               <p class="font-bold text-white text-lg">Especialistas CMS</p>
               <p class="text-white/60 text-sm">{datePub.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
             </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Contenido Principal & Sidebar -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 md:mt-20">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
        
        <!-- Arquitectura de Lectura (Prose) -->
        <div class="w-full lg:w-8/12">
          <!-- Estilos inyectados nativos adaptados según regla de tipografía -->
          <div class="prose prose-lg md:prose-xl max-w-none prose-headings:text-brand-blue prose-headings:font-bold prose-p:text-slate-600 prose-p:leading-relaxed prose-p:font-sans prose-li:text-slate-600 prose-a:text-brand-cyan hover:prose-a:text-brand-blue prose-strong:text-slate-800" set:html={article.content}>
          </div>

          <!-- Tags -->
          {article.tags && article.tags.length > 0 && (
            <div class="mt-12 pt-8 border-t border-slate-100 flex flex-wrap gap-2">
              <span class="text-sm font-semibold text-slate-400 mr-2 flex items-center"><i class="ph ph-tag mr-1"></i> Etiquetas:</span>
              {article.tags.map((tag: string) => (
                 <span class="bg-slate-50 text-slate-500 px-3 py-1 rounded-md text-sm hover:bg-slate-100 transition-colors cursor-pointer">
                   #{tag}
                 </span>
              ))}
            </div>
          )}
        </div>

        <!-- Sidebar de Conversión (Sticky) -->
        <aside class="w-full lg:w-4/12">
          <div class="sticky top-32 bg-slate-50 border border-slate-100 rounded-[32px] p-8 shadow-lg shadow-brand-blue/5 text-center">
            <div class="w-16 h-16 bg-white rounded-2xl shadow-sm border border-slate-100 flex items-center justify-center mx-auto mb-6 text-brand-cyan">
              <i class="ph ph-stethoscope text-4xl"></i>
            </div>
            <h3 class="text-2xl font-bold text-brand-blue mb-4">¿Buscas un especialista en este tema?</h3>
            <p class="text-slate-600 mb-8 leading-relaxed">
              Nuestro equipo médico está certificado internacionalmente para brindarte el mejor diagnóstico en {mainCat.toLowerCase()}.
            </p>
            <a href="/directorio" class="flex items-center justify-center w-full px-6 py-4 bg-brand-cyan text-white font-bold rounded-2xl hover:bg-cyan-600 transition-colors shadow-md shadow-brand-cyan/20">
              Ir al Directorio Médico <i class="ph ph-arrow-right ml-2 text-xl"></i>
            </a>
            
            <div class="mt-6 pt-6 border-t border-slate-200">
               <p class="text-sm text-slate-400 mb-4 font-semibold uppercase tracking-wider">Línea Directa 24/7</p>
               <a href="tel:8192453678" class="text-slate-800 font-bold text-lg hover:text-brand-cyan transition-colors">
                  (81) 9245 3678
               </a>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </article>

</Layout>
