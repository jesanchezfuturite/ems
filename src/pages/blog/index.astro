---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';

// Llamada al API
let articles: any[] = [];
try {
  const res = await fetch('https://hospital.futurite.info/api/v1/public/blog-articles');
  const json = await res.json();
  if (json.Code === 200 && json.data) {
    articles = json.data;
  } else if (Array.isArray(json)) {
    articles = json;
  }
} catch (err) {
  console.error("Error fetching articles", err);
}

// Asegurar ordenamiento (más reciente primero) si existe created_at
if (articles.length > 0 && articles[0].created_at) {
  articles.sort((a, b) => new Date(b.created_at).valueOf() - new Date(a.created_at).valueOf());
}

// Función auxiliar para extraer extractos (excerpts) seguros desde HTML (limpiando tags rudimentariamente)
const stripHtml = (html: string) => {
  if (!html) return "";
  return html.replace(/<[^>]*>?/gm, '').substring(0, 160) + '...';
};

// Formato de Fecha
const formatDate = (dateStr: string) => {
  if(!dateStr) return 'Reciente';
  return new Date(dateStr).toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' });
};

// Separar Destacados de Regulares
const featuredPosts = articles.slice(0, 4); // Tomamos los últimos 4 como destacados para el slider
const regularPosts = articles; // Mostrar todos en el grid, o slice(4) si prefieren no repetir

// Categorías únicas basadas en los tags
const allTagsSet = new Set<string>();
articles.forEach(article => {
  if (article.tags && Array.isArray(article.tags)) {
    article.tags.forEach(t => allTagsSet.add(t));
  }
});
const categories = ['Todas', ...Array.from(allTagsSet)];

// --- SEO Schema Markup ---
const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Revista Médica Digital - CMS",
  "description": "Artículos médicos sobre salud, cirugía y prevención.",
  "blogPost": articles.map(post => ({
    "@type": "BlogPosting",
    "headline": post.title,
    "image": post.cover_image,
    "datePublished": post.created_at,
    "author": {
      "@type": "Organization",
      "name": "Centro de Especialidades Médicas"
    }
  }))
};
---

<Layout 
  title="Revista Médica Digital | Centro de Especialidades Médicas"
  description="Mantente informado con los artículos médicos más recientes sobre nuestro catálogo de especialidades: maternidad, bariatría, salud y tecnología quirúrgica."
>
  <!-- SEO JSON-LD Override in body (or it can go to head if layout supports slot="head", but script block is fine) -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

  <style is:global>
    /* Ocultar barra de scroll para el menú lateral */
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    
    /* Configuración de Paginación Swiper */
    .swiper-pagination-bullet {
      background: rgba(255, 255, 255, 0.5) !important;
      opacity: 1 !important;
    }
    .swiper-pagination-bullet-active {
      background: #00a3e0 !important; /* brand-cyan */
      width: 24px !important;
      border-radius: 8px !important;
      transition: all 0.3s ease;
    }
  </style>

  <section class="bg-slate-50 pt-16 pb-12 overflow-hidden relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Hero Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-4 text-transparent bg-clip-text bg-gradient-to-r from-brand-blue to-brand-cyan drop-shadow-sm pb-2">
          Revista Médica Digital
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
          Autoridad, innovación y prevención. Descubre lo último en medicina directamente de nuestros especialistas certificados.
        </p>
      </div>

      <!-- Slider Destacados (Swiper) -->
      {featuredPosts.length > 0 && (
        <div class="relative w-full mb-16 rounded-[32px] shadow-2xl overflow-hidden">
          <div class="swiper blog-featured-swiper w-full h-[450px] md:h-[550px]">
            <div class="swiper-wrapper">
              {featuredPosts.map((post) => (
                <div class="swiper-slide relative w-full h-full group group/slide">
                  <a href={`/blog/${post.slug}`} class="block w-full h-full">
                    <!-- Background Image con efecto scale sutil -->
                    <img 
                      src={post.cover_image} 
                      alt={post.title} 
                      class="absolute inset-0 w-full h-full object-cover transform sm:scale-100 sm:group-hover:scale-105 transition-transform duration-1000 ease-in-out" 
                    />
                    <!-- Overlay de Gradiente Oscuro -->
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/30 to-slate-900/10"></div>
                    
                    <!-- Contenedor Glass Card -->
                    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-12 z-20">
                      <div class="glass-card p-6 md:p-8 rounded-[24px] max-w-3xl transform translate-y-8 opacity-0 group-[.swiper-slide-active]/slide:opacity-100 group-[.swiper-slide-active]/slide:translate-y-0 transition-all duration-700 delay-300">
                        <span class="inline-block bg-brand-cyan text-white px-3 py-1 rounded-md text-xs font-bold tracking-widest uppercase mb-4 shadow-sm border border-brand-cyan/50">
                          {post.tags && post.tags.length > 0 ? post.tags[0] : 'Destacado'}
                        </span>
                        <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-slate-900 mb-3 leading-tight drop-shadow-sm">
                          {post.title}
                        </h2>
                        <p class="text-slate-800 line-clamp-2 mb-4 text-base md:text-lg font-medium opacity-90">
                          {stripHtml(post.content)}
                        </p>
                        <div class="flex items-center text-slate-700 text-sm font-bold">
                          <div class="w-8 h-8 rounded-full bg-brand-blue text-white flex items-center justify-center overflow-hidden border border-slate-200 mr-3">
                            <i class="ph ph-stethoscope text-lg"></i>
                          </div>
                          <span>Centro de Especialidades</span>
                          <span class="mx-3 text-slate-400">•</span>
                          <span>{formatDate(post.created_at)}</span>
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
              ))}
            </div>
            <!-- Swiper Controls -->
            <div class="swiper-pagination mb-2"></div>
            <div class="swiper-button-prev hidden md:flex !text-white after:!text-2xl !w-12 !h-12 bg-black/20 rounded-full backdrop-blur-sm border border-white/20 hover:bg-brand-blue transition-colors"></div>
            <div class="swiper-button-next hidden md:flex !text-white after:!text-2xl !w-12 !h-12 bg-black/20 rounded-full backdrop-blur-sm border border-white/20 hover:bg-brand-blue transition-colors"></div>
          </div>
        </div>
      )}

      <!-- Navegación de Categorías -->
      <div class="mb-10 w-full overflow-hidden relative">
        <div class="flex overflow-x-auto scrollbar-hide space-x-3 py-4 pl-1 snap-x shadow-inner-sm" id="blog-filters">
          {categories.map((cat, index) => (
            <button 
              class={`blog-chip snap-start flex-shrink-0 px-6 py-2.5 rounded-full text-sm font-bold transition-all duration-300 transform active:scale-95 ${index === 0 ? 'bg-brand-blue text-white shadow-lg shadow-brand-blue/30' : 'bg-white text-slate-600 border border-slate-200 hover:border-brand-cyan hover:text-brand-cyan hover:shadow-md'}`}
              data-filter={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- Grid Regular de Artículos -->
  <section class="py-12 bg-slate-50 min-h-[50vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div id="blog-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {regularPosts.map((post) => (
          <div class="blog-grid-item" data-category={post.tags && post.tags.length > 0 ? post.tags.join(',') : 'General'}>
            <BlogCard 
              title={post.title}
              excerpt={stripHtml(post.content)}
              image={post.cover_image}
              category={post.tags && post.tags.length > 0 ? post.tags[0] : 'General'}
              date={formatDate(post.created_at)}
              slug={post.slug}
            />
          </div>
        ))}
      </div>

      <!-- Empty State For Filters -->
      <div id="no-articles-msg" class={articles.length === 0 ? "text-center py-16" : "hidden text-center py-16"}>
        <div class="bg-white w-24 h-24 mx-auto rounded-full flex items-center justify-center mb-6 text-slate-300 shadow-sm border border-slate-100">
           <i class="ph ph-article-ny-times text-5xl"></i>
        </div>
        <h3 class="text-2xl font-bold text-brand-blue mb-2">Sin artículos coincidentes</h3>
        <p class="text-slate-500 text-lg">Actualmente no existen publicaciones filtradas con tu búsqueda.</p>
      </div>

    </div>
  </section>

  <!-- Lógica y Animaciones -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Inicializar Swiper
      if (typeof window.Swiper !== 'undefined') {
        new window.Swiper('.blog-featured-swiper', {
          slidesPerView: 1,
          loop: true,
          autoplay: {
            delay: 6000,
            disableOnInteraction: false,
          },
          effect: 'fade',
          fadeEffect: {
            crossFade: true
          },
          pagination: {
            el: '.swiper-pagination',
            clickable: true,
          },
          navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev',
          },
        });
      }

      // 2. Animaciones GSAP Grid Artículos (Aparición Escalada y Transición)
      if (typeof window.gsap !== 'undefined') {
        window.gsap.from('.blog-grid-item', {
          y: 40,
          opacity: 0,
          duration: 0.8,
          stagger: 0.1,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#blog-grid",
            start: "top 85%",
          }
        });
      }

      // 3. Lógica de Filtrado por Categorías (Pills)
      const chips = document.querySelectorAll('.blog-chip');
      const items = document.querySelectorAll('.blog-grid-item');
      const emptyMsg = document.getElementById('no-articles-msg');

      chips.forEach(chip => {
        chip.addEventListener('click', (e) => {
          const btn = e.currentTarget;
          const filter = btn.getAttribute('data-filter');

          // Estilos Activos
          chips.forEach(c => {
             c.classList.remove('bg-brand-blue', 'text-white', 'shadow-lg', 'shadow-brand-blue/30');
             c.classList.add('bg-white', 'text-slate-600', 'hover:border-brand-cyan');
          });
          btn.classList.remove('bg-white', 'text-slate-600', 'hover:border-brand-cyan');
          btn.classList.add('bg-brand-blue', 'text-white', 'shadow-lg', 'shadow-brand-blue/30');

          // Aplicar Filtro (con simple display logic o gsap si se prefiere)
          let visibleCount = 0;
          items.forEach(item => {
            const catStr = item.getAttribute('data-category');
            if (!catStr) return;
            const tags = catStr.split(',');
            if (filter === 'Todas' || tags.includes(filter)) {
              item.style.display = 'block';
              visibleCount++;
            } else {
              item.style.display = 'none';
            }
          });

          // Empty State
          if(visibleCount === 0) {
            emptyMsg.classList.remove('hidden');
          } else {
            emptyMsg.classList.add('hidden');
          }
          
          // Re-trigger scrollTrigger para GSAP si se actualiza el layout (opcional)
          if(window.ScrollTrigger) window.ScrollTrigger.refresh();
        });
      });
    });
  </script>
</Layout>
