---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Especialidades from '../components/Especialidades.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalOrganization",
  "name": "Centro de Especialidades Médicas",
  "url": "https://christus.mx/sur",
  "logo": "/images/logo.png",
  "medicalSpecialty": [
    "Bariatrics",
    "Maternity",
    "Traumatology"
  ]
};
---

<Layout 
  title="Centro de Especialidades Médicas | Excelencia Médica y Quirúrgica en Monterrey"
  description="Líderes en Cirugía Bariátrica, Maternidad y Urgencias 24/7. Tecnología de vanguardia y los mejores especialistas certificados en Monterrey."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <Hero />

  <Especialidades />

  <!-- Sección de Autoridad (Social Proof) -->
  <section class="py-16 bg-white border-t border-slate-100 overflow-hidden relative z-10 shadow-[-10px_-10px_30px_rgba(0,0,0,0.02)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-lg font-bold text-slate-400 mb-10 cert-item uppercase tracking-wider">Hospital Certificado: Estándares internacionales de seguridad para el paciente</h2>
      
      <div class="swiper mySwiper cert-item max-w-4xl mx-auto">
        <div class="swiper-wrapper flex items-center">
          <div class="swiper-slide flex justify-center opacity-70 hover:opacity-100 transition-opacity duration-300">
            <img src="/images/jci-logo.webp" alt="Joint Commission International" class="h-16 object-contain grayscale hover:grayscale-0 transition-all duration-300" />
          </div>
          <div class="swiper-slide flex justify-center opacity-70 hover:opacity-100 transition-opacity duration-300">
            <img src="/images/csg-logo.webp" alt="Consejo de Salubridad General" class="h-16 object-contain grayscale hover:grayscale-0 transition-all duration-300" />
          </div>
          <div class="swiper-slide flex justify-center opacity-70 hover:opacity-100 transition-opacity duration-300">
            <img src="/images/jci-logo.webp" alt="Joint Commission International 2" class="h-16 object-contain grayscale hover:grayscale-0 transition-all duration-300" />
          </div>
          <div class="swiper-slide flex justify-center opacity-70 hover:opacity-100 transition-opacity duration-300">
            <img src="/images/csg-logo.webp" alt="Consejo de Salubridad General 2" class="h-16 object-contain grayscale hover:grayscale-0 transition-all duration-300" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Swiper Setup
      if (typeof Swiper !== 'undefined') {
        new Swiper('.mySwiper', {
          slidesPerView: 2,
          spaceBetween: 30,
          loop: true,
          autoplay: {
            delay: 3000,
            disableOnInteraction: false,
          },
          breakpoints: {
            768: {
              slidesPerView: 4,
              spaceBetween: 40,
            },
          },
        });
      }

      // ScrollTrigger para la sección de certificaciones
      if (typeof gsap !== 'undefined' && gsap.plugins && gsap.plugins.ScrollTrigger) {
        gsap.fromTo(".cert-item", 
          { y: 20, opacity: 0 },
          { 
            y: 0, opacity: 1, stagger: 0.2, duration: 1, ease: "power3.out",
            scrollTrigger: {
              trigger: ".cert-section, .mySwiper", // fallback in case cert-section class was removed
              start: "top 85%",
            }
          }
        );
      }
    });
  </script>
</Layout>
