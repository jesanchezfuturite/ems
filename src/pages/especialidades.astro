                 <a href={`/especialidades/${slugify(spec.nombre)}`} class="text-sky-600 font-semibold text-sm flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
                   Ver más <i class="ph ph-arrow-right ml-1"></i>
                 </a>
