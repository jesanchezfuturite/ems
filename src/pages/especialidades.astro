---
import Layout from "../layouts/Layout.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalBusiness",
      "name": "Centro de Especialidades Médicas en Monterrey",
      "image": "https://christus.mx/sur/images/cirugia_gen.webp",
      "@id": "https://christus.mx/sur",
      "url": "https://christus.mx/sur",
      "telephone": "+528180000000",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Av. Principal 123",
        "addressLocality": "Monterrey",
        "addressRegion": "NL",
        "postalCode": "64000",
        "addressCountry": "MX"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuándo debo acudir a un especialista médico?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Debes acudir a un especialista cuando presentas síntomas persistentes, dolor continuo o cuando necesitas un diagnóstico más preciso en áreas como cardiología, neurología o gastroenterología."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué hace un médico especialista?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un especialista es un médico con formación avanzada en un área específica, capacitado para diagnosticar y tratar enfermedades complejas de forma más precisa."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo elegir la especialidad médica correcta?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Depende de tus síntomas. Por ejemplo, problemas digestivos corresponden a gastroenterología, síntomas respiratorios a neumología y afecciones de la piel a dermatología."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué estudios debo llevar a mi primera consulta?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Se recomienda llevar estudios previos, análisis clínicos, radiografías o cualquier historial médico que ayude al especialista a evaluar tu caso de forma más completa."
          }
        },
        {
          "@type": "Question",
          "name": "¿Necesito referencia médica para consultar a un especialista?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No es necesario. Puedes agendar directamente con el especialista indicado según tus síntomas o necesidades."
          }
        }
      ]
    }
  ]
};

// Especialidades Estáticas
const apiSpecialties = [
  { nombre: "Alergología e Inmunología", desc: "Especialistas en el diagnóstico y tratamiento de alergias (alimentarias, estacionales, cutáneas) y enfermedades del sistema inmunológico como el asma y rinitis." },
  { nombre: "Angiología", desc: "Expertos en salud vascular. Tratamiento de várices, insuficiencia venosa, trombosis y enfermedades de arterias y vasos linfáticos." },
  { nombre: "Audiología, Otoneurología y Foniatría", desc: "Diagnóstico y rehabilitación de problemas de audición, trastornos del equilibrio (vértigo) y alteraciones de la voz y el lenguaje." },
  { nombre: "Cardiología", desc: "Especialistas en la salud del corazón. Prevención y tratamiento de hipertensión, arritmias, infartos y enfermedades cardiovasculares." },
  { nombre: "Cardiología Clínica", desc: "Enfoque en el diagnóstico no invasivo y manejo médico de enfermedades cardíacas crónicas y prevención de riesgos coronarios." },
  { nombre: "Cirugía General", desc: "Especialistas en procedimientos quirúrgicos del aparato digestivo, sistema endocrino y reparación de hernias o patologías abdominales." },
  { nombre: "Cirugia Pediatrica", desc: "Intervenciones quirúrgicas especializadas en niños y adolescentes, desde recién nacidos hasta la etapa de crecimiento." },
  { nombre: "Cirugía Plástica y Reconstructiva", desc: "Procedimientos estéticos y reconstructivos para mejorar la apariencia o corregir anomalías congénitas, quemaduras y traumatismos." },
  { nombre: "Cirujano General", desc: "Médico experto en cirugías de emergencia y programadas para tratar afecciones abdominales, tejidos blandos y glándulas." },
  { nombre: "Dermatología", desc: "Cuidado integral de la piel, cabello y uñas. Tratamiento de acné, manchas, cáncer de piel, dermatitis y procedimientos estéticos dermatológicos." },
  { nombre: "Endocrinología", desc: "Especialistas en hormonas y metabolismo. Manejo de diabetes, trastornos de la tiroides, obesidad, SOP y desequilibrios hormonales." },
  { nombre: "Gastroenterología", desc: "Diagnóstico y tratamiento de enfermedades del aparato digestivo: gastritis, colitis, reflujo, úlceras y realización de endoscopias." },
  { nombre: "Geriatría", desc: "Atención médica especializada para adultos mayores, enfocada en un envejecimiento saludable y el manejo de enfermedades crónico-degenerativas." },
  { nombre: "Ginecología y Obstetricia", desc: "Salud integral de la mujer. Control prenatal, atención del parto, salud reproductiva, menopausia y prevención de cáncer cervicouterino." },
  { nombre: "Hematología", desc: "Expertos en enfermedades de la sangre y órganos hematopoyéticos, como anemia, leucemia, linfomas y problemas de coagulación." },
  { nombre: "Hepatología", desc: "Especialidad enfocada exclusivamente en el hígado, vesícula biliar y vías biliares. Tratamiento de hepatitis, cirrosis e hígado graso." },
  { nombre: "Infectología", desc: "Diagnóstico y tratamiento de enfermedades causadas por virus, bacterias, parásitos o hongos (VIH, infecciones respiratorias, hepatitis, etc.)." },
  { nombre: "Medicina Crítica", desc: "Médicos intensivistas dedicados al cuidado de pacientes en estado grave o crítico dentro de la Unidad de Cuidados Intensivos (UCI)." },
  { nombre: "Medicina de Urgencias", desc: "Atención inmediata de emergencias médicas y situaciones que ponen en riesgo la vida del paciente de forma súbita." },
  { nombre: "Medicina Familiar", desc: "Atención médica primaria y continua para todos los miembros de la familia, con un enfoque preventivo y de salud integral." },
  { nombre: "Medicina General", desc: "Consulta médica de primer contacto para diagnósticos iniciales, chequeos generales y referencia a especialistas." },
  { nombre: "Medicina Interna", desc: "Atención integral del adulto. Expertos en el manejo de enfermedades complejas y múltiples padecimientos crónicos simultáneos." },
  { nombre: "Nefrología", desc: "Especialistas en la salud de los riñones. Tratamiento de insuficiencia renal, cálculos renales, hipertensión arterial y diálisis." },
  { nombre: "Neumología", desc: "Diagnóstico y tratamiento de enfermedades respiratorias y de los pulmones como EPOC, asma, apnea del sueño y neumonía." },
  { nombre: "Neurocirugía", desc: "Especialistas en cirugía del sistema nervioso, incluyendo cerebro, columna vertebral y nervios periféricos." },
  { nombre: "Neurología", desc: "Tratamiento de trastornos del sistema nervioso: migrañas, epilepsia, Alzheimer, Parkinson y accidentes cerebrovasculares." },
  { nombre: "Nutrición Clínica", desc: "Diseño de planes de alimentación terapéuticos para pacientes con enfermedades específicas, control de peso y mejora de hábitos alimenticios." },
  { nombre: "Odontología", desc: "Cuidado integral de la salud bucodental. Tratamiento de caries, limpieza dental, ortodoncia, endodoncia y estética dental." },
  { nombre: "Oftalmología", desc: "Salud visual y cuidado de los ojos. Tratamiento de cataratas, glaucoma, miopía, astigmatismo y cirugías oculares." },
  { nombre: "Ortopedia", desc: "Diagnóstico y tratamiento de lesiones o deformidades en huesos, articulaciones, ligamentos y tendones." },
  { nombre: "Otorrinolaringología", desc: "Especialistas en oído, nariz y garganta. Tratamiento de sinusitis, pérdida de audición, amigdalitis y problemas de equilibrio." },
  { nombre: "Otorrinolaringología y Cirugía de Cabeza y Cuello", desc: "Tratamiento avanzado de patologías complejas que afectan el área facial, el cuello y las vías aéreas superiores." },
  { nombre: "Pediatra", desc: "Cuidado médico integral para bebés, niños y adolescentes, monitoreando su crecimiento, desarrollo y esquema de vacunación." },
  { nombre: "Pediatría", desc: "Cuidado médico integral para bebés, niños y adolescentes, monitoreando su crecimiento, desarrollo y esquema de vacunación." },
  { nombre: "Psicología", desc: "Apoyo terapéutico para la salud mental. Manejo de ansiedad, depresión, estrés y procesos emocionales a través de terapia." },
  { nombre: "Psiquiatría", desc: "Diagnóstico y tratamiento médico de trastornos mentales y del comportamiento, con enfoque en el equilibrio clínico y farmacológico." },
  { nombre: "Traumatología y Ortopedia", desc: "Especialistas en fracturas, lesiones deportivas y cirugías de reemplazo articular (cadera, rodilla, hombro)." },
  { nombre: "Urología", desc: "Salud del sistema urinario en hombres y mujeres, y del aparato reproductor masculino. Tratamiento de próstata y cálculos renales." }
];

function getSpecData(name) {
  const n = name.toLowerCase();
  let icon = "ph-stethoscope";
  if (n.includes('cardio')) icon = "ph-heartbeat";
  else if (n.includes('gastro')) icon = "ph-first-aid";
  else if (n.includes('pediat')) icon = "ph-baby";
  else if (n.includes('ortop') || n.includes('traum')) icon = "ph-activity";
  else if (n.includes('neuro')) icon = "ph-brain";
  else if (n.includes('derm')) icon = "ph-hand";
  else if (n.includes('neumo')) icon = "ph-wind";
  else if (n.includes('psiq') || n.includes('psic')) icon = "ph-brain";
  else if (n.includes('hepa')) icon = "ph-drop";
  else if (n.includes('hema')) icon = "ph-drop";
  else if (n.includes('gine') || n.includes('obste')) icon = "ph-baby";
  else if (n.includes('uro')) icon = "ph-drop";
  else if (n.includes('cirug')) icon = "ph-scissors";
  else if (n.includes('onco') || n.includes('cancer')) icon = "ph-dna";
  else if (n.includes('alergi') || n.includes('inmun')) icon = "ph-plant";
  else if (n.includes('bariat')) icon = "ph-person";
  else if (n.includes('electro')) icon = "ph-activity";
  else if (n.includes('endo')) icon = "ph-drop";
  else if (n.includes('geri')) icon = "ph-users";
  else if (n.includes('infec')) icon = "ph-shield-plus";

  return { icon };
}

function slugify(text) {
  if (!text) return '';
  return text.toString().toLowerCase().trim()
    .normalize('NFD') // remove accents
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/\s+/g, '-') // spaces to dashes
    .replace(/[^\w\-]+/g, '') // remove non-words
    .replace(/\-\-+/g, '-'); // collapse dashes
}

const initialSpecs = apiSpecialties.slice(0, 9);
const remainingSpecs = apiSpecialties.slice(9);
---

<Layout
