      {remainingSpecs.length > 0 && (
        <div class="mt-20 mb-8 text-center" id="loadMoreContainer">
          <button id="loadMoreBtn" class="px-8 py-4 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 hover:text-sky-600 font-bold rounded-2xl shadow-sm transition-all focus:ring-4 focus:ring-sky-100 flex items-center justify-center mx-auto gap-2">
            Cargar más especialidades <i class="ph ph-caret-down font-bold"></i>
          </button>
        </div>
      )}

      <!-- Store remaining elements in JS variable safely -->
      <script type="application/json" id="remainingSpecData" set:html={JSON.stringify(remainingSpecs)}></script>
    </div>
  </section>

  <!-- 3. Bloques de Autoridad y Confianza -->
  <section class="py-24 bg-white relative overflow-hidden">
