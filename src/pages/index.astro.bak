---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Especialidades from '../components/Especialidades.astro';

// AEO: JSON-LD Graph for System (MedicalOrganization + FAQPage)
const aeoSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalOrganization",
      "@id": "https://christus.mx/sur/#organization",
      "name": "Centro de Especialidades Médicas",
      "url": "https://christus.mx/sur",
      "logo": "https://christus.mx/images/logo.png",
      "medicalSpecialty": [
        "Cardiology",
        "Gastroenterology",
        "Gynecology",
        "Traumatology"
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://christus.mx/sur/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué especialidades médicas ofrecen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Contamos con más de 40 especialidades médicas, incluyendo cardiología, gastroenterología, ginecología y traumatología, enfocadas en brindar diagnóstico y tratamiento integral."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo puedo agendar una consulta con un especialista?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Puedes agendar tu cita directamente desde nuestro sitio web o contactar a nuestro equipo para ayudarte a encontrar al especialista adecuado."
          }
        },
        {
          "@type": "Question",
          "name": "¿Aceptan seguros de gastos médicos mayores?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, trabajamos con diversas aseguradoras. Te recomendamos verificar cobertura y condiciones al momento de agendar tu consulta."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo elegir al especialista adecuado para mi caso?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Depende de tus síntomas o diagnóstico previo. Si tienes dudas, nuestro equipo puede orientarte para canalizarte con el médico correcto."
          }
        }
      ]
    }
  ]
};
---

<Layout 
  title="Centro de Especialidades Médicas | Médicos Certificados en Monterrey"
  description="Encuentra a los mejores médicos especialistas certificados en Monterrey. Atendemos más de 40 especialidades con tecnología de vanguardia y atención integral."
>
  <script type="application/ld+json" set:html={JSON.stringify(aeoSchema)} />

  <Hero />

  <Especialidades />

  <!-- Bloque de Autoridad y confianza (E-E-A-T) -->
  <section class="py-24 bg-white relative z-20 shadow-[0_-20px_40px_-20px_rgba(0,0,0,0.05)] border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 authority-header">
        <h2 class="text-brand-blue font-bold tracking-widest uppercase text-sm mb-3">Atención médica certificada</h2>
        <h3 class="text-3xl md:text-5xl font-black text-slate-800 tracking-tight">Compromiso con tu <span class="text-[#00a3e0]">salud</span></h3>
        <p class="text-slate-600 text-lg md:text-xl font-medium mt-6 max-w-2xl mx-auto">
          Nuestro cuerpo médico e instalaciones están respaldados por los más estrictos consejos y normativas de calidad nacionales e internacionales.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto authority-cards">
        <div class="glass-card p-10 flex flex-col items-center text-center hover:-translate-y-1 transition-transform">
          <img src="/images/jci-logo.webp" alt="Joint Commission International" class="h-24 object-contain mb-6 grayscale hover:grayscale-0 transition-all duration-300" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 50\'><rect width=\'100\' height=\'50\' fill=\'%23f1f5f9\'/><text x=\'50\' y=\'25\' dominant-baseline=\'middle\' text-anchor=\'middle\' font-size=\'10\' fill=\'%2394a3b8\'>JCI Logo</text></svg>'" />
          <h4 class="text-xl font-bold text-[#004b87] mb-2">Acreditación JCI</h4>
          <p class="text-slate-600 text-sm">Garantizamos estándares y protocolos avalados globalmente para tu máxima seguridad.</p>
        </div>

        <div class="glass-card p-10 flex flex-col items-center text-center hover:-translate-y-1 transition-transform">
          <img src="/images/csg-logo.webp" alt="Consejo de Salubridad General" class="h-24 object-contain mb-6 grayscale hover:grayscale-0 transition-all duration-300" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 50\'><rect width=\'100\' height=\'50\' fill=\'%23f1f5f9\'/><text x=\'50\' y=\'25\' dominant-baseline=\'middle\' text-anchor=\'middle\' font-size=\'10\' fill=\'%2394a3b8\'>CSG Logo</text></svg>'" />
          <h4 class="text-xl font-bold text-[#004b87] mb-2">Certificación CSG</h4>
          <p class="text-slate-600 text-sm">Validación a nivel nacional que ratifica nuestra excelencia operativa e institucional.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección FAQ Avanzada (AEO / Zero-click searches) -->
  <section class="py-24 bg-slate-50 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-br from-[#00a3e0]/5 to-transparent pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16 faq-header">
        <h2 class="text-3xl md:text-5xl font-black text-[#004b87] tracking-tight mb-4">Preguntas Frecuentes</h2>
        <p class="text-slate-600 text-lg md:text-xl font-medium">Respuestas rápidas para facilitarte el acceso a tu atención médica.</p>
      </div>

      <div class="space-y-6 faq-items">
        <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] border-l-4 border-l-transparent hover:border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
          <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
            ¿Qué especialidades médicas ofrecen?
            <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
          </summary>
          <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4">
            Contamos con más de 40 especialidades médicas, incluyendo cardiología, gastroenterología, ginecología y traumatología, enfocadas en brindar diagnóstico y tratamiento integral.
          </div>
        </details>

        <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] border-l-4 border-l-transparent hover:border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
          <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
            ¿Cómo puedo agendar una consulta con un especialista?
            <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
          </summary>
          <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4">
            Puedes agendar tu cita directamente desde nuestro sitio web o contactar a nuestro equipo para ayudarte a encontrar al especialista adecuado.
          </div>
        </details>

        <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] border-l-4 border-l-transparent hover:border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
          <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
            ¿Aceptan seguros de gastos médicos mayores?
            <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
          </summary>
          <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4">
            Sí, trabajamos con diversas aseguradoras. Te recomendamos verificar cobertura y condiciones al momento de agendar tu consulta.
          </div>
        </details>

        <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] border-l-4 border-l-transparent hover:border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
          <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
            ¿Cómo elegir al especialista adecuado para mi caso?
            <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
          </summary>
          <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4">
            Depende de tus síntomas o diagnóstico previo. Si tienes dudas, nuestro equipo puede orientarte para canalizarte con el médico correcto.
          </div>
        </details>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Opcional: Acordeón comportamiento nativo - Cerrar los otros al abrir uno
      const faqs = document.querySelectorAll('.faq-items details');
      faqs.forEach(faq => {
        faq.addEventListener('click', (e) => {
          faqs.forEach(otherFaq => {
            if(otherFaq !== faq && otherFaq.hasAttribute('open')) {
              otherFaq.removeAttribute('open');
            }
          });
        });
      });

      // Animaciones GSAP
      if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
        
        // Autoridad
        gsap.fromTo(".authority-header", 
          { y: 30, opacity: 0 },
          { y: 0, opacity: 1, duration: 1, ease: "power3.out", scrollTrigger: { trigger: ".authority-header", start: "top 85%" } }
        );
        gsap.fromTo(".authority-cards > div", 
          { y: 40, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.8, stagger: 0.2, ease: "back.out(1.5)", scrollTrigger: { trigger: ".authority-cards", start: "top 80%" } }
        );

        // FAQs
        gsap.fromTo(".faq-header", 
          { y: 30, opacity: 0 },
          { y: 0, opacity: 1, duration: 1, ease: "power3.out", scrollTrigger: { trigger: ".faq-header", start: "top 85%" } }
        );
        gsap.fromTo(".faq-items details", 
          { x: -30, opacity: 0 },
          { x: 0, opacity: 1, duration: 0.6, stagger: 0.15, ease: "power2.out", scrollTrigger: { trigger: ".faq-items", start: "top 75%" } }
        );
      }
    });
  </script>
</Layout>
