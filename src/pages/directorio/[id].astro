---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  try {
    const res = await fetch('https://administrador.especialidadesmedicassur.com.mx/api/directorio-medico/search?per_page=1000');
    const items = await res.json();
    let doctors: any[] = [];
    if (Array.isArray(items)) {
      doctors = items;
    } else if (items.data && Array.isArray(items.data)) {
      doctors = items.data;
    } else if (items.data && items.data.data && Array.isArray(items.data.data)) {
      doctors = items.data.data;
    }
    
    return doctors.map((doc: any) => {
      // Usar string in params siempre
      return {
        params: { id: doc.id.toString() }
      };
    });
  } catch(error) {
    console.error("Error fetching getStaticPaths in directorio/[id].astro", error);
    return [];
  }
}

const { id } = Astro.params;

// Traer perfil completo
let profile: any = null;
try {
  const profileRes = await fetch(`https://administrador.especialidadesmedicassur.com.mx/api/directorio-medico/get/${id}`);
  const profileJson = await profileRes.json();
  // Validamos si la respuesta viene dentro de Code y data según el formato proporcionado.
  profile = profileJson.data ? profileJson.data : profileJson;
} catch (e) {
  console.error("Error al traer el perfil completo", e);
}

if (!profile || Object.keys(profile).length === 0) {
  return Astro.redirect('/directorio');
}

// Variables útiles e interpolaciones seguras
const svgFallback = `data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='100%' height='100%' viewBox='0 0 100 100'><rect fill='%23f1f5f9' width='100' height='100'/><path fill='%23cbd5e1' d='M50 50c11.046 0 20-8.954 20-20s-8.954-20-20-20-20 8.954-20 20 8.954 20 20 20zm0 10c-13.314 0-40 6.671-40 20v10h80V80c0-13.329-26.686-20-40-20z'/></svg>`;
const profileImg = profile.foto || svgFallback;
const especialidadNombre = profile.especialidad ? profile.especialidad.nombre : 'Especialista';

// Check de arreglos vacíos o nulos
const hasData = (arr: any) => Array.isArray(arr) && arr.length > 0;
---

<Layout 
  title={`${profile.nombre} - ${especialidadNombre} | Directorio Médico`} 
  description={profile.introduccion || `Conoce la trayectoria clínica de ${profile.nombre}, certificado en ${especialidadNombre}. Agenda tu cita hoy.`}
>
  <!-- Hero Section del Perfil -->
  <section class="relative bg-slate-50 pt-20 pb-16 md:pt-28 md:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-cyan/10 to-transparent"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <div class="bg-white/80 backdrop-blur-xl rounded-3xl p-8 md:p-12 shadow-2xl shadow-brand-blue/5 border border-white">
        <!-- Tarjeta Principal -->
        <div class="flex flex-col md:flex-row items-center md:items-start gap-8">
          <div class="flex-shrink-0">
            <div class="w-32 h-32 md:w-48 md:h-48 rounded-full overflow-hidden border-4 border-white shadow-xl bg-slate-50 relative">
              <img src={profileImg} alt={profile.nombre} class="w-full h-full object-cover" />
            </div>
          </div>
          <div class="text-center md:text-left flex-grow">
            <div class="inline-block px-4 py-1.5 mb-3 bg-brand-cyan/10 text-brand-cyan text-sm font-bold rounded-full uppercase tracking-wider">
              {especialidadNombre}
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-brand-blue mb-2 leading-tight">{profile.nombre}</h1>
            {profile.subespecialidad && <p class="text-lg text-slate-600 font-medium mb-4">{profile.subespecialidad}</p>}
            
            <p class="text-slate-600 leading-relaxed max-w-xl mb-6">
              {profile.introduccion || "Especialista comprometido con la salud y bienestar de sus pacientes, brindando un trato humano y altamente capacitado con tecnología de vanguardia."}
            </p>

            <div class="flex flex-wrap gap-4 justify-center md:justify-start">
              <a href="/contacto" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-sm md:text-base font-bold rounded-full text-white bg-brand-cyan hover:bg-cyan-600 transition-colors shadow-lg shadow-brand-cyan/30">
                <i class="ph ph-calendar-plus text-xl mr-2"></i>
                Agendar Cita
              </a>
              <a href="/directorio" class="inline-flex items-center justify-center px-6 py-3 border border-slate-200 text-sm md:text-base font-bold rounded-full text-slate-600 bg-white hover:bg-slate-50 transition-colors shadow-sm">
                Regresar al Directorio
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Detalles de la Trayectoria -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        
        <!-- Columna Izquierda (Resumen Técnico) -->
        <div class="space-y-8">
          
          <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
            <h3 class="text-brand-blue font-bold text-lg mb-4 flex items-center border-b border-slate-200 pb-2">
              <i class="ph ph-identification-card text-brand-cyan mr-2 text-xl"></i> Cédulas
            </h3>
            <ul class="space-y-3 text-sm text-slate-600">
              <li>
                <span class="block text-slate-400 text-xs uppercase tracking-wider mb-0.5">Profesional</span>
                {profile.cedula_profesional || 'En trámite'}
              </li>
              {profile.cedula_especialidad && (
                <li>
                  <span class="block text-slate-400 text-xs uppercase tracking-wider mb-0.5">Especialidad</span>
                  {profile.cedula_especialidad}
                </li>
              )}
            </ul>
          </div>

          <!-- Información General -->
          <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
             <h3 class="text-brand-blue font-bold text-lg mb-4 flex items-center border-b border-slate-200 pb-2">
              <i class="ph ph-info text-brand-cyan mr-2 text-xl"></i> General
            </h3>
            <ul class="space-y-3 text-sm text-slate-600">
              {profile.edad && (
                <li class="flex items-center">
                  <i class="ph ph-user text-slate-400 mr-2 text-lg"></i> Edad: {profile.edad} años
                </li>
              )}
              {profile.genero && (
                <li class="flex items-center">
                  <i class="ph ph-gender-intersex text-slate-400 mr-2 text-lg"></i> Género: {profile.genero}
                </li>
              )}
              {hasData(profile.idiomas) && (
                <li class="flex items-start">
                  <i class="ph ph-translate text-slate-400 mr-2 text-lg mt-0.5"></i> 
                  <span class="capitalize">{profile.idiomas.join(', ')}</span>
                </li>
              )}
            </ul>
          </div>

          <!-- Grupos Demos -->
          <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
            <h3 class="text-brand-blue font-bold text-lg mb-4 flex items-center border-b border-slate-200 pb-2">
              <i class="ph ph-users text-brand-cyan mr-2 text-xl"></i> Atiende a
            </h3>
            <div class="flex flex-wrap gap-2 text-sm text-slate-600">
              {profile.atiende_adultos === 1 && <span class="bg-white px-3 py-1 rounded-md border border-slate-200 shadow-sm">Adultos</span>}
              {profile.atiende_menores === 1 && <span class="bg-white px-3 py-1 rounded-md border border-slate-200 shadow-sm">Menores (Pediatría)</span>}
              {(profile.atiende_adultos !== 1 && profile.atiende_menores !== 1) && <span class="text-slate-400 italic">No especificado</span>}
            </div>
          </div>

        </div>

        <!-- Columna Derecha Principal (Trayectoria) -->
        <div class="md:col-span-2 space-y-14">
          
          {hasData(profile.grados_academicos) && profile.grados_academicos.filter((g: any) => g.titulo || g.institucion).length > 0 && (
            <div class="relative">
              <h2 class="text-2xl font-bold text-brand-blue mb-6 flex items-center">
                <i class="ph ph-graduation-cap text-brand-cyan mr-3 text-3xl"></i> Grados Académicos
              </h2>
              <ul class="space-y-5 relative before:absolute before:inset-0 before:ml-2 before:-translate-x-px md:before:mx-0 md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-200 before:to-transparent pl-8 md:pl-6">
                {profile.grados_academicos.filter((g: any) => g.titulo || g.institucion).map((grado: any) => (
                  <li class="relative">
                    <div class="absolute w-3 h-3 bg-brand-cyan rounded-full -left-9 mt-1.5 border-2 border-white shadow-sm ring-1 ring-brand-cyan/20"></div>
                    <p class="text-slate-700 leading-relaxed bg-slate-50/70 p-4 rounded-xl border border-slate-100 shadow-sm">
                      <strong class="text-brand-blue">{grado.titulo}</strong>
                      {grado.institucion && `, ${grado.institucion}`}
                      {grado.nota && ` (${grado.nota})`}
                    </p>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {hasData(profile.experiencia_profesional) && profile.experiencia_profesional.filter((e: any) => e.puesto || e.institucion).length > 0 && (
            <div>
              <h2 class="text-2xl font-bold text-brand-blue mb-6 flex items-center">
                <i class="ph ph-briefcase text-brand-cyan mr-3 text-3xl"></i> Experiencia Profesional
              </h2>
              <div class="grid grid-cols-1 gap-4">
                {profile.experiencia_profesional.filter((e: any) => e.puesto || e.institucion).map((exp: any) => (
                  <div class="flex items-start bg-slate-50/50 p-4 rounded-xl border border-slate-100 shadow-sm">
                    <i class="ph ph-check-circle text-brand-cyan mt-1 mr-3 text-xl flex-shrink-0"></i>
                    <p class="text-slate-700 leading-relaxed">
                       <strong class="text-brand-blue">{exp.puesto}</strong>
                       {exp.institucion && ` en ${exp.institucion}`}
                       {exp.periodo && ` (${exp.periodo})`}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {hasData(profile.certificaciones) && (
            <div>
              <h2 class="text-2xl font-bold text-brand-blue mb-6 flex items-center">
                <i class="ph ph-seal-check text-brand-cyan mr-3 text-3xl"></i> Certificaciones
              </h2>
              <div class="flex flex-wrap gap-3">
                {profile.certificaciones.map((cert: string) => (
                  <span class="inline-flex items-center px-4 py-2.5 rounded-full text-sm font-semibold bg-brand-cyan/10 text-brand-blue border border-brand-cyan/20 shadow-sm">
                    <i class="ph ph-medal mr-2 text-brand-cyan text-lg"></i>
                    {cert}
                  </span>
                ))}
              </div>
            </div>
          )}

          {hasData(profile.enfoque_clinico) && (
            <div>
              <h2 class="text-2xl font-bold text-brand-blue mb-6 flex items-center">
                <i class="ph ph-heartbeat text-brand-cyan mr-3 text-3xl"></i> Enfoque Clínico
              </h2>
              <div class="bg-brand-blue rounded-3xl p-8 md:p-10 text-white shadow-xl shadow-brand-blue/20 relative overflow-hidden">
                <div class="absolute -right-10 -top-10 opacity-10">
                  <i class="ph ph-heartbeat text-[150px]"></i>
                </div>
                <ul class="space-y-4 grid grid-cols-1 sm:grid-cols-2 gap-x-6 relative z-10">
                  {profile.enfoque_clinico.map((enfoque: string) => (
                    <li class="flex items-start">
                       <i class="ph ph-star text-brand-cyan mt-1 mr-3 text-lg flex-shrink-0"></i>
                       <span class="text-white/90 leading-relaxed">{enfoque}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

        </div>
      </div>

    </div>
  </section>
</Layout>
