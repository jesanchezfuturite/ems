  </section>

  <!-- Animaciones GSAP -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      setTimeout(() => {
        if (typeof window.gsap !== "undefined" && window.ScrollTrigger) {
          
          // Parallax Hero
          window.gsap.to(".parallax-bg", {
            yPercent: 15,
            ease: "none",
            scrollTrigger: {
              trigger: ".hero-section",
              start: "top top",
              end: "bottom top",
              scrub: true
            }
          });

          // Animación Stagger Tipos de Trasplantes
          window.gsap.from(".tj-card", {
            scrollTrigger: {
              trigger: ".list-trasplantes",
              start: "top 80%",
            },
            y: 40,
            opacity: 0,
            duration: 0.6,
            stagger: 0.15,
            ease: "power3.out",
            clearProps: "all",
          });

          // Animación Stepper Proceso
          window.gsap.from(".stepper-tr", {
            scrollTrigger: {
              trigger: ".process-section",
              start: "top 75%",
            },
            y: 50,
            opacity: 0,
            duration: 0.6,
            stagger: 0.15,
            ease: "back.out(1.2)",
            clearProps: "all",
          });

        }
      }, 100);
    });
  </script>

