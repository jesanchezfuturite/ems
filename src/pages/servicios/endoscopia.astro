  <!-- Animaciones GSAP -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      setTimeout(() => {
        if (typeof window.gsap !== "undefined" && window.ScrollTrigger) {
          
          // Animación Stagger Soft Reveal Padecimientos y Catálogo
          window.gsap.from(".catalog-card, .pad-list > div", {
            scrollTrigger: {
              trigger: ".catalog-list",
              start: "top 80%",
            },
            y: 30,
            opacity: 0,
            duration: 0.6,
            stagger: 0.1,
            ease: "power2.out",
            clearProps: "all",
          });

          // Animación Stepper Despliegue Secuencial
          window.gsap.from(".stepper-tr", {
            scrollTrigger: {
              trigger: ".process-section",
              start: "top 75%",
            },
            y: 40,
            opacity: 0,
            duration: 0.6,
            stagger: 0.15,
            ease: "power3.out",
            clearProps: "all",
          });

        }
      }, 100);
    });
  </script>

