  <!-- Animaciones GSAP -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      setTimeout(() => {
        if (typeof window.gsap !== "undefined" && window.ScrollTrigger) {
          
          // Animación Stagger Paquetes Check Up
          window.gsap.from(".pkg-card", {
            scrollTrigger: {
              trigger: ".pkg-grid",
              start: "top 80%",
            },
            y: 40,
            scale: 0.95,
            opacity: 0,
            duration: 0.6,
            stagger: 0.1,
            ease: "back.out(1.2)",
            clearProps: "all",
          });

          // Animación Stepper Proceso Check Up
          window.gsap.from(".stepper-chk", {
            scrollTrigger: {
              trigger: ".process-section",
              start: "top 75%",
            },
            y: 50,
            opacity: 0,
            duration: 0.6,
            stagger: 0.15,
            ease: "power3.out",
            clearProps: "all",
          });

        }
      }, 100);
    });
  </script>

