---
import Layout from "../../layouts/Layout.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Banco de Sangre",
      "provider": {
        "@type": "MedicalBusiness",
        "name": "Centro Médico en Monterrey",
        "url": "https://midominio.com"
      },
      "description": "Servicio de banco de sangre disponible 24/7. Donación segura con los más altos estándares médicos y tecnología de vanguardia en Monterrey.",
      "areaServed": "Monterrey, Nuevo León",
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://midominio.com/servicios/banco-de-sangre",
        "providesService": {
          "@type": "MedicalSpecialty",
          "name": "Hematology"
        }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cómo agendar mi cita para donar sangre?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Puedes agendar tu cita comunicándote directamente a través de nuestro botón de WhatsApp o llamando a nuestra línea de atención 24/7."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto dura el proceso de donación?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El proceso completo, desde tu llegada, la valoración clínica, la extracción y la recuperación, dura aproximadamente entre 45 y 60 minutos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Puedo donar si tomo medicamentos?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Depende del medicamento. Algunos medicamentos comunes no impiden la donación, pero es indispensable mencionarlo durante la encuesta médica para una valoración clínica segura."
          }
        }
      ]
    }
  ]
};
---

<Layout
  title="Banco de Sangre en Monterrey | Donación Segura 24/7"
  description="Donación de sangre segura 24/7 con los más altos estándares de calidad. Salva vidas hoy en nuestro Banco de Sangre."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <style>
    /* Estilo exigido en prompt */
    .glass-card {
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
    }
  </style>

  <!-- Hero Section -->
  <section class="relative bg-[#004b87] pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden text-white">
    <div class="absolute inset-0 z-0">
      <img src="/images/img_donacion_sangre.webp" alt="Donación de Sangre en Monterrey" class="w-full h-full object-cover opacity-20 mix-blend-overlay" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#004b87] via-[#004b87]/90 to-[#004b87]/40"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col xl:flex-row items-center gap-12 lg:gap-16">
      <div class="w-full xl:w-1/2 flex flex-col items-start z-10">
        <span class="inline-block bg-[#00a3e0]/20 text-[#00a3e0] px-4 py-1.5 rounded-full text-sm font-semibold tracking-wide border border-[#00a3e0]/30 mb-6 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#e11d48] animate-pulse"></span>
          Urgencias 24/7 Disponibles
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-5xl font-extrabold text-white mb-6 leading-[1.15]">
          Banco de Sangre en Monterrey: Donación Segura 24/7
        </h1>
        <p class="text-lg md:text-xl text-slate-200 mb-10 max-w-xl leading-relaxed">
          Brindamos atención personalizada a donadores, pacientes y familiares con los más altos estándares de calidad, seguridad y tecnología médica.
        </p>
        <a href="#agenda" class="inline-flex items-center justify-center px-8 py-4 bg-[#e11d48] text-white text-lg font-bold rounded-2xl hover:bg-rose-500 transition-all shadow-xl shadow-rose-900/30 transform hover:-translate-y-1">
          Donar Sangre Ahora <i class="ph ph-heartbeat text-2xl ml-2"></i>
        </a>
      </div>
      
      <div class="w-full xl:w-1/2 relative hidden md:block">
        <div class="relative w-full aspect-[4/3] rounded-[2rem] overflow-hidden shadow-2xl shadow-slate-900/50 border border-[#00a3e0]/20">
           <img src="/images/img_donacion_sangre.webp" alt="Área de procesamiento del Banco de Sangre" class="w-full h-full object-cover object-center scale-100 hover:scale-105 transition-transform duration-700" />
           <div class="absolute inset-0 bg-gradient-to-t from-[#004b87]/80 via-transparent to-transparent pointer-events-none"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bloque de Confianza -->
  <section class="relative z-20 -mt-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="glass-card rounded-2xl p-6 grid grid-cols-2 md:grid-cols-4 gap-6 bg-white/95">
      <div class="flex items-center gap-4 group">
        <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-[#00a3e0] group-hover:bg-[#00a3e0] group-hover:text-white transition-colors">
          <i class="ph ph-clock text-2xl"></i>
        </div>
        <p class="font-bold text-slate-800 text-sm leading-tight">Atención 24/7</p>
      </div>
      <div class="flex items-center gap-4 group">
        <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-[#00a3e0] group-hover:bg-[#00a3e0] group-hover:text-white transition-colors">
          <i class="ph ph-user-focus text-2xl"></i>
        </div>
        <p class="font-bold text-slate-800 text-sm leading-tight">Personal Capacitado</p>
      </div>
      <div class="flex items-center gap-4 group">
        <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-[#00a3e0] group-hover:bg-[#00a3e0] group-hover:text-white transition-colors">
          <i class="ph ph-flask text-2xl"></i>
        </div>
        <p class="font-bold text-slate-800 text-sm leading-tight">Tecnología de Vanguardia</p>
      </div>
      <div class="flex items-center gap-4 group">
        <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-[#00a3e0] group-hover:bg-[#00a3e0] group-hover:text-white transition-colors">
          <i class="ph ph-shield-check text-2xl"></i>
        </div>
        <p class="font-bold text-slate-800 text-sm leading-tight">Estándares Internacionales</p>
      </div>
    </div>
  </section>

  <!-- Definición AEO & Emoción -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
        <!-- Izquierda AEO -->
        <div class="glass-card bg-white p-8 md:p-10 rounded-[2rem] border border-slate-200">
          <h2 class="text-3xl font-bold text-[#004b87] mb-6 flex items-center gap-3">
            <i class="ph ph-info text-[#00a3e0]"></i> ¿Qué es un banco de sangre?
          </h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-4 font-medium">
            Un banco de sangre es una instalación médica especializada y regulada encargada de recolectar, analizar, procesar y almacenar sangre y sus componentes (plasma, plaquetas y glóbulos rojos).
          </p>
          <p class="text-slate-600 leading-relaxed">
            Nuestro objetivo es garantizar una transfusión segura a pacientes que lo requieren por cirugías, traumatismos, condiciones crónicas o emergencias médicas, cumpliendo estrictamente con las normativas sanitarias vigentes.
          </p>
        </div>

        <!-- Derecha Emocional -->
        <div class="bg-[#004b87] backdrop-blur-md p-8 md:p-10 rounded-[2rem] border border-[#004b87]/80 text-white relative overflow-hidden shadow-xl shadow-slate-200/50">
          <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-[#e11d48] rounded-full blur-[80px] opacity-40 mix-blend-screen"></div>
          <h2 class="text-3xl font-bold text-white mb-6 flex items-center gap-3 relative z-10">
            <i class="ph ph-heart text-[#e11d48]"></i> Donar sangre salva vidas
          </h2>
          <p class="text-slate-200 text-lg leading-relaxed mb-6 font-medium relative z-10">
            Cada donación es un acto de amor puro y altruista. Con una sola aportación, tienes el poder de ayudar a restaurar la vida de hasta tres personas diferentes.
          </p>
          <p class="text-slate-300 leading-relaxed relative z-10">
            Imagina el impacto: estás regalando esperanza, recuperando sonrisas de familias enteras y brindando un mañana a quienes hoy enfrentan su momento más crítico. Sé el héroe de alguien hoy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Requisitos & Preparación -->
  <section class="py-20 relative bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Checklist Requisitos -->
        <div class="lg:col-span-7">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8">
            Requisitos de Donación
          </h2>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 requirements-list">
            <li class="req-item glass-card bg-slate-50 p-4 rounded-xl flex items-start gap-4">
              <i class="ph ph-check-circle text-2xl text-[#00a3e0] flex-shrink-0 mt-0.5"></i>
              <span class="text-slate-700 font-medium h-full flex items-center">Edad entre 18 y 65 años.</span>
            </li>
            <li class="req-item glass-card bg-slate-50 p-4 rounded-xl flex items-start gap-4">
              <i class="ph ph-check-circle text-2xl text-[#00a3e0] flex-shrink-0 mt-0.5"></i>
              <span class="text-slate-700 font-medium h-full flex items-center">Peso mínimo de 50 kg.</span>
            </li>
            <li class="req-item glass-card bg-slate-50 p-4 rounded-xl flex items-start gap-4">
              <i class="ph ph-check-circle text-2xl text-[#00a3e0] flex-shrink-0 mt-0.5"></i>
              <span class="text-slate-700 font-medium h-full flex items-center">Identificación oficial vigente con fotografía.</span>
            </li>
            <li class="req-item glass-card bg-slate-50 p-4 rounded-xl flex items-start gap-4">
              <i class="ph ph-check-circle text-2xl text-[#00a3e0] flex-shrink-0 mt-0.5"></i>
              <span class="text-slate-700 font-medium h-full flex items-center">Buen estado de salud general (sin infecciones recientes).</span>
            </li>
            <li class="req-item glass-card bg-slate-50 p-4 rounded-xl flex items-start gap-4">
              <i class="ph ph-check-circle text-2xl text-[#00a3e0] flex-shrink-0 mt-0.5"></i>
              <span class="text-slate-700 font-medium h-full flex items-center">No haber tenido cirugías en los últimos 6 meses.</span>
            </li>
            <li class="req-item glass-card bg-slate-50 p-4 rounded-xl flex items-start gap-4">
              <i class="ph ph-check-circle text-2xl text-[#00a3e0] flex-shrink-0 mt-0.5"></i>
              <span class="text-slate-700 font-medium">Sin tatuajes o perforaciones recientes (últimos 12 meses).</span>
            </li>
            <li class="req-item glass-card bg-slate-50 p-4 rounded-xl flex items-start gap-4">
              <i class="ph ph-check-circle text-2xl text-[#00a3e0] flex-shrink-0 mt-0.5"></i>
              <span class="text-slate-700 font-medium">Ayuno mínimo de 4 horas (evitando grasas).</span>
            </li>
            <li class="req-item glass-card bg-slate-50 p-4 rounded-xl flex items-start gap-4">
              <i class="ph ph-check-circle text-2xl text-[#00a3e0] flex-shrink-0 mt-0.5"></i>
              <span class="text-slate-700 font-medium">Mujeres: no estar embarazadas ni en periodo de lactancia.</span>
            </li>
          </ul>
        </div>

        <!-- Preparación para donar -->
        <div class="lg:col-span-5">
          <div class="glass-card bg-[#00a3e0]/10 border-[#00a3e0]/20 p-8 rounded-[2rem] h-full">
            <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center text-[#00a3e0] mb-6 shadow-sm">
              <i class="ph ph-apple-logo text-3xl"></i>
            </div>
            <h3 class="text-2xl font-bold text-[#004b87] mb-4">
              ¿Cómo prepararte para donar sangre?
            </h3>
            <div class="space-y-4">
               <!-- Preparación Items -->
               <div class="flex items-start gap-3">
                 <div class="w-2 h-2 rounded-full bg-[#e11d48] mt-2 flex-shrink-0"></div>
                 <p class="text-slate-700"><strong>Hidratación:</strong> Consume abundantes líquidos (agua o jugos naturales) antes de acudir.</p>
               </div>
               <div class="flex items-start gap-3">
                 <div class="w-2 h-2 rounded-full bg-[#e11d48] mt-2 flex-shrink-0"></div>
                 <p class="text-slate-700"><strong>Alimentación:</strong> Realiza una comida ligera y libre de grasas si donarás por la tarde. Evita el ayuno prolongado superior a 8 horas.</p>
               </div>
               <div class="flex items-start gap-3">
                 <div class="w-2 h-2 rounded-full bg-[#e11d48] mt-2 flex-shrink-0"></div>
                 <p class="text-slate-700"><strong>Descanso:</strong> Duerme al menos de 6 a 8 horas la noche previa a tu donación.</p>
               </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso de Donación (Stepper Visual) -->
  <section class="py-24 bg-slate-50 relative process-section border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20 max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-bold text-[#004b87] mb-6">
          El proceso de donación
        </h2>
        <p class="text-lg text-slate-600">
          Un protocolo clínico, ágil y de absoluta seguridad para protegerte a ti y a nuestros pacientes.
        </p>
      </div>

      <div class="relative max-w-5xl mx-auto px-2 md:px-0">
        <!-- Línea conectora Desktop -->
        <div class="hidden md:block absolute top-[2.5rem] left-[15%] right-[15%] h-[2px] bg-slate-200 z-0"></div>
        <!-- Línea conectora Mobile -->
        <div class="block md:hidden absolute top-8 bottom-8 left-[2.4rem] w-[2px] bg-slate-200 z-0"></div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-6 relative z-10">
          
          <div class="stepper-item flex md:flex-col items-start md:items-center text-left md:text-center relative gap-6 md:gap-0">
             <div class="w-16 h-16 md:w-20 md:h-20 bg-white rounded-full shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 flex items-center justify-center text-[#00a3e0] flex-shrink-0 z-10 md:mb-6">
               <span class="text-2xl font-black">1</span>
             </div>
             <div>
                <h4 class="text-lg font-bold text-slate-900 mb-2 mt-1 md:mt-0">Encuesta Médica</h4>
                <p class="text-sm text-slate-500 leading-relaxed max-w-xs md:max-w-none md:mx-auto">Cuestionario confidencial sobre tu historial clínico y hábitos de vida.</p>
             </div>
          </div>

          <div class="stepper-item flex md:flex-col items-start md:items-center text-left md:text-center relative gap-6 md:gap-0">
             <div class="w-16 h-16 md:w-20 md:h-20 bg-[#00a3e0] rounded-full shadow-[0_10px_40px_-10px_rgba(0,163,224,0.4)] border-4 border-slate-50 flex items-center justify-center text-white flex-shrink-0 z-10 md:mb-6">
               <span class="text-2xl font-black">2</span>
             </div>
             <div>
                <h4 class="text-lg font-bold text-slate-900 mb-2 mt-1 md:mt-0">Valoración Clínica</h4>
                <p class="text-sm text-slate-500 leading-relaxed max-w-xs md:max-w-none md:mx-auto">Examen físico por nuestros médicos que revisan signos vitales y niveles de sangre.</p>
             </div>
          </div>

          <div class="stepper-item flex md:flex-col items-start md:items-center text-left md:text-center relative gap-6 md:gap-0">
             <div class="w-16 h-16 md:w-20 md:h-20 bg-white rounded-full shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 flex items-center justify-center text-[#00a3e0] flex-shrink-0 z-10 relative md:mb-6">
               <span class="absolute -top-1 -right-1 w-4 h-4 bg-[#e11d48] rounded-full animate-pulse"></span>
               <span class="text-2xl font-black">3</span>
             </div>
             <div>
                <h4 class="text-lg font-bold text-slate-900 mb-2 mt-1 md:mt-0">Donación</h4>
                <p class="text-sm text-slate-500 leading-relaxed max-w-xs md:max-w-none md:mx-auto">Proceso de extracción realizado con material estéril y punción segura que toma ~10 minutos.</p>
             </div>
          </div>

          <div class="stepper-item flex md:flex-col items-start md:items-center text-left md:text-center relative gap-6 md:gap-0">
             <div class="w-16 h-16 md:w-20 md:h-20 bg-white rounded-full shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 flex items-center justify-center text-[#00a3e0] flex-shrink-0 z-10 md:mb-6">
               <span class="text-2xl font-black">4</span>
             </div>
             <div>
                <h4 class="text-lg font-bold text-slate-900 mb-2 mt-1 md:mt-0">Recuperación</h4>
                <p class="text-sm text-slate-500 leading-relaxed max-w-xs md:max-w-none md:mx-auto">Breve reposo donde te brindaremos alimentos y líquidos antes de que te retires.</p>
             </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA de Cierre -->
  <section id="agenda" class="py-20 relative bg-[#004b87] overflow-hidden">
    <div class="absolute -top-[50%] -left-[10%] w-[500px] h-[500px] bg-[#00a3e0] rounded-full blur-[150px] opacity-30"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
       <h2 class="text-4xl md:text-5xl font-black text-white mb-6">Agenda tu donación</h2>
       <p class="text-xl text-slate-200 mb-10 max-w-2xl mx-auto">
         Contáctanos para revisar disponibilidad, confirmar requisitos o atenderte ante una urgencia clínica. Estamos listos para recibirte.
       </p>
       <div class="flex justify-center">
         <a href="/contacto" class="inline-flex items-center justify-center px-10 py-5 bg-[#00a3e0] text-white text-lg font-bold rounded-2xl hover:bg-white hover:text-[#004b87] transition-all shadow-xl shadow-[#00a3e0]/30 transform hover:-translate-y-1">
           <i class="ph ph-calendar-check text-2xl mr-3"></i> Agendar mi Donación
         </a>
       </div>
    </div>
  </section>

  <!-- Sección FAQ -->
  <section class="py-24 bg-white relative">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 faq-header">
        <h2 class="text-3xl md:text-5xl font-black text-[#004b87] tracking-tight mb-4">Preguntas Frecuentes</h2>
        <p class="text-slate-600 text-lg md:text-xl font-medium">Información útil sobre la donación de sangre.</p>
      </div>

      <div class="space-y-6 faq-items">
        <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] !border-l-[4px] !border-l-transparent hover:!border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
          <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
            ¿Cómo agendar mi cita para donar sangre?
            <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
          </summary>
          <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4 pr-8">
            Puedes agendar tu cita comunicándote directamente a través de nuestro botón de WhatsApp o llamando a nuestra línea de atención 24/7.
          </div>
        </details>
        
        <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] !border-l-[4px] !border-l-transparent hover:!border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
          <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
            ¿Cuánto dura el proceso de donación?
            <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
          </summary>
          <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4 pr-8">
            El proceso completo, desde tu llegada, la valoración clínica, la extracción y la recuperación, dura aproximadamente entre 45 y 60 minutos.
          </div>
        </details>

        <details class="glass-card rounded-2xl p-6 group cursor-pointer marker:content-[''] !border-l-[4px] !border-l-transparent hover:!border-l-[#00a3e0] transition-all overflow-hidden bg-white/60 shadow-sm hover:shadow-md">
          <summary class="text-xl font-bold text-[#004b87] flex justify-between items-center outline-none list-none marker:content-none [&::-webkit-details-marker]:hidden">
            ¿Puedo donar si tomo medicamentos?
            <i class="ph ph-caret-down transform group-open:rotate-180 transition-transform text-[#00a3e0] text-2xl"></i>
          </summary>
          <div class="mt-4 text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-4 pr-8">
            Depende del medicamento. Algunos medicamentos comunes no impiden la donación, pero es indispensable mencionarlo durante la encuesta médica para una valoración clínica segura.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Animaciones GSAP -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      setTimeout(() => {
        if (typeof window.gsap !== "undefined" && window.ScrollTrigger) {
          
          // Animación Stepper
          window.gsap.from(".stepper-item", {
            scrollTrigger: {
              trigger: ".process-section",
              start: "top 75%",
            },
            y: 50,
            opacity: 0,
            duration: 0.6,
            stagger: 0.2,
            ease: "power2.out",
            clearProps: "all",
          });

          // Animación Checklist (Fade-In Up)
          window.gsap.from(".req-item", {
            scrollTrigger: {
              trigger: ".requirements-list",
              start: "top 85%",
            },
