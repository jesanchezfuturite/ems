  <!-- Animaciones GSAP -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      setTimeout(() => {
        if (typeof window.gsap !== "undefined" && window.ScrollTrigger) {
          
          // Animación Stagger Infraestructura
          window.gsap.from(".infra-card", {
            scrollTrigger: {
              trigger: ".infra-grid",
              start: "top 80%",
            },
            y: 40,
            opacity: 0,
            duration: 0.6,
            stagger: 0.15,
            ease: "back.out(1.2)",
            clearProps: "all",
          });

          // Animación Stepper Proceso Terapia
          window.gsap.from(".stepper-tr", {
            scrollTrigger: {
              trigger: ".process-section",
              start: "top 75%",
            },
            y: 50,
            opacity: 0,
            duration: 0.6,
            stagger: 0.15,
            ease: "power3.out",
            clearProps: "all",
          });

          // Pulso Sutil en Modulo de Monitoreo Fondo Hero
          window.gsap.to(".monitor-pulse", {
            opacity: 0.3,
            scale: 1.05,
            yoyo: true,
            repeat: -1,
            ease: "sine.inOut",
            duration: 1.5
          });

          // Pulsos de Ondas EKG
          window.gsap.to(".monitor-wave", {
            opacity: 0.6,
            x: 20,
            yoyo: true,
            repeat: -1,
            ease: "sine.inOut",
            duration: 2
          });

        }
      }, 100);
    });
  </script>

