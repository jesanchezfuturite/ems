---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
}

const {
  title,
  description = "Centro de Especialidades Médicas - Excelencia Médica a tu alcance.",
  canonicalURL = Astro.url.href,
} = Astro.props;

const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "MedicalOrganization",
  name: "Centro de Especialidades Médicas",
  url: canonicalURL,
  logo: "/images/logo.webp",

  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+52-81-0000-0000",
    contactType: "Urgencias",
    availableLanguage: ["es", "en"],
  },
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts: Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- CDNs (Phosphor Icons, Swiper) -->
    <script src="https://unpkg.com/@phosphor-icons/web" defer></script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    />

    <!-- Schema.org JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schemaMarkup)}
    />
  </head>
  <body
    class="font-sans antialiased bg-slate-50 text-slate-900 overflow-x-hidden"
  >
    <Header />


    <!-- Slot Content wrapped in GSAP animation container -->
    <main
      id="main-content"
      class="min-h-screen pt-20"
    >
      <slot />
    </main>

    <Footer />
    <!-- GSAP & Scripts -->
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
      defer></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
      defer></script>
    <script
      src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
      defer></script>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        // En Astro este event listener asegura que se ejecute después de cargar el DOM
        if (typeof window.gsap !== "undefined") {
          // Registra plugins
          window.gsap.registerPlugin(window.ScrollTrigger);

          // Animación inicial Fade-in + Scale
          window.gsap.from("#main-content", {
            duration: 1,
            opacity: 0,
            scale: 0.95,
            ease: "power3.out",
            clearProps: "all",
          });
        }
      });
    </script>
  </body>
</html>
